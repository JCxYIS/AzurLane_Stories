lor": "#92fc63"}, {"say": "응? 너무 기뻐서… 정신을 잃었다고……?", "actor": 206031, "actorName": "유니콘 [작은 별의 디바 ]", "nameColor": "#92fc63"}, {"say": "오빠…… (///)", "actor": 206031, "actorName": "유니콘 [작은 별의 디바 ]", "nameColor": "#92fc63"}, {"say": "…….고마워…… 오빠…… 오빠가 기쁘면, 유니콘도 기쁜걸? ……역시 스타더스트님이 말한 대로야…", "actor": 206031, "actorName": "유니콘 [작은 별의 디바 ]", "nameColor": "#92fc63"}, {"say": "\"자그마한 용기야말로 가장 강한 마법\"…… 에헤헤♪", "actor": 206031, "actorName": "유니콘 [작은 별의 디바 ]", "nameColor": "#92fc63"}]}, "TW": {"演唱會的門票": [{"sequence": ["小小的勇氣&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">一  演唱會的門票</span><br>"]}, {"say": "某一天，港區", "narration": true}, {"say": "不知道指揮官…哥哥找獨角獸有什麼事…", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "不過…能見到哥哥…就好開心了…嘻嘻……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "幾分鐘後，港區指揮室", "narration": true}, {"say": "獨角獸…報到…找獨角獸有什麼事情嗎？哥哥？", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"bgName": "bg_story_star0"}, {"say": "這個是……？票？", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "演-唱-會？雖然不是很明白那是什麼……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "（……）", "actor": 0, "actorName": "0", "nameColor": "#a9f548"}, {"say": "和哥哥……一起去？", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "難道……這就是傳說中的……ㄩㄝ-ㄏㄨㄟˋ？", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "嘻嘻……能和哥哥一起出去，獨角獸……很期待……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}], "LIVE「平行四界」": [{"stopbgm": true, "sequence": ["小小的勇氣&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">二  LIVE「平行四界」</span><br>"]}, {"say": "星塵演唱會現場", "narration": true}, {"bgm": "star", "bgName": "bg_story_star1", "say": "唔噢噢噢噢！星塵醬最棒了啊啊啊啊啊！！", "actorName": "觀眾A", "nameColor": "#a9f548"}, {"say": "星塵醬我們愛妳啊啊啊啊！！！", "actorName": "觀眾B", "nameColor": "#a9f548"}, {"say": "哈啊……哈啊……", "actorName": "觀眾C", "nameColor": "#a9f548"}, {"say": "謝謝大家的應援～我已經感受到妳們的感情了～讓我們更加燃起來吧～！", "actorName": "星塵", "nameColor": "#a9f548"}, {"say": "哦噢噢噢噢！L！！O！！V！！E！！星•塵•醬！L！！O！！V！！E！！星•塵•醬！", "actorName": "台下眾人", "nameColor": "#a9f548"}, {"say": "大、大家都好熱情……哥、哥哥呢？", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "（！！！！！）", "actor": 0, "actorName": "0", "nameColor": "#a9f548"}, {"say": "哥哥……好興奮的樣子……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "好像……很開心……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "謝謝大家～星塵的歌～有沒有傳達到大家的心中呢～？讓我們期待下一次再會吧！", "actorName": "星塵", "nameColor": "#a9f548"}, {"say": "哦噢噢噢噢哦噢噢噢噢！", "actorName": "台下眾人", "nameColor": "#a9f548"}, {"say": "哈啊～～果然星塵醬是最棒的～", "actorName": "觀眾A", "nameColor": "#a9f548"}, {"say": "感覺……此生無憾了……", "actorName": "觀眾B", "nameColor": "#a9f548"}, {"say": "不行，我還要活著等到下次星塵醬的演唱會呢！", "actorName": "觀眾C", "nameColor": "#a9f548"}, {"say": "這就是……歌唱的力量嗎……好厲害……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "感覺獨角獸……都被感染了一樣……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "獨角獸也想……讓哥哥那麼開心……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}], "獨角獸的煩惱": [{"sequence": ["小小的勇氣&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">三  獨角獸的煩惱</span><br>"]}, {"say": "幾天後……", "narration": true}, {"say": "哈啊……獨角獸……想不明白……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "那時候的哥哥……好像全身都散發著光芒一樣……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "有種……輸了的感覺……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "（猛搖頭）嗯嗯，不對…獨角獸只是…想要讓指揮官……哥哥開心……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "哈啊……究竟怎麼做……才能讓哥哥……那麼開心呢……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "星塵……姐姐嗎？嗯……感覺那個姐姐身上……也散發著光芒呢……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "哥哥好像說過……“不恥下問”？", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "獨角獸……要去問問那位姐姐……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}], "給星塵的信": [{"stopbgm": true, "sequence": ["小小的勇氣&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">四  給星塵的信</span><br>"]}, {"bgName": "bg_story_star2"}], "星塵的回音": [{"stopbgm": true, "sequence": ["小小的勇氣&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">五  星塵的回音</span><br>"]}, {"bgName": "bg_story_star3", "say": "“前略，親愛的獨角獸妹妹：”", "actorName": "星塵", "nameColor": "#a9f548"}, {"say": "“很高興能收到妳的來信，沒想到能多了一個這麼可愛的小小歌迷呢”", "actorName": "星塵", "nameColor": "#a9f548"}, {"say": "“從妳的信裡，可以充分感受到妳的心意”", "actorName": "星塵", "nameColor": "#a9f548"}, {"say": "“獨角獸真的很喜歡妳的指揮官哥哥呀～”", "actorName": "星塵", "nameColor": "#a9f548"}, {"say": "“因為感情而甦醒的我說出來的話，肯定不會錯的”", "actorName": "星塵", "nameColor": "#a9f548"}, {"say": "“對於這麼可愛的獨角獸妹妹，就讓姐姐給妳一點小小的建議吧”", "actorName": "星塵", "nameColor": "#a9f548"}, {"say": "“小小的勇氣就是最大的魔法、喲”", "actorName": "星塵", "nameColor": "#a9f548"}, {"say": "“踏出一小步，讓獨角獸的哥哥看看不一樣的妳吧！”", "actorName": "星塵", "nameColor": "#a9f548"}, {"say": "“我會在這裡為妳加油的”", "actorName": "星塵", "nameColor": "#a9f548"}, {"say": "“為妳應援的歌姬 星塵”", "actorName": "星塵", "nameColor": "#a9f548"}], "改變的勇氣": [{"sequence": ["小小的勇氣&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">六  改變的勇氣</span><br>"]}, {"say": "怎、怎麼辦……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "雖然從星塵姐姐那裡收到了這個……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "嗚……果然還是好害羞……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "而且…這麼華麗的衣服…獨角獸…一定不合適的…要是哥哥不喜歡…怎麼辦…", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "小小的勇氣……就是最大的魔法……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "嗯！獨角獸，會加油的！", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}], "小小的魔法": [{"sequence": ["小小的勇氣&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">七  小小的魔法</span><br>"]}, {"say": "哥、哥哥……在獨角獸說可以之前，不可以睜開眼睛哦……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "嗚…果然還是……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "星塵姐姐……給我勇氣……", "actor": 206030, "actorName": "獨角獸", "nameColor": "#a9f548"}, {"say": "（唱歌）……", "actor": 206031, "actorName": "獨角獸 [小小的星之歌姬]", "nameColor": "#a9f548"}, {"say": "呼……怎、怎麼樣……星塵姐姐送的這套衣服……還有這首歌……", "actor": 206031, "actorName": "獨角獸 [小小的星之歌姬]", "nameColor": "#a9f548"}, {"say": "星塵姐姐說這樣……就能讓哥哥開心……", "actor": 206031, "actorName": "獨角獸 [小小的星之歌姬]", "nameColor": "#a9f548"}, {"say": "獨角獸…有努力了吧？", "actor": 206031, "actorName": "獨角獸 [小小的星之歌姬]", "nameColor": "#a9f548"}, {"say": "欸？哥、哥哥？！！！", "actor": 206031, "actorName": "獨角獸 [小小的星之歌姬]", "nameColor": "#a9f548"}, {"say": "呼…還好……哥哥沒什麼事…", "actor": 206031, "actorName": "獨角獸 [小小的星之歌姬]", "nameColor": "#a9f548"}, {"say": "嗯？太興奮所以暈過去了？", "actor": 206031, "actorName": "獨角獸 [小小的星之歌姬]", "nameColor": "#a9f548"}, {"say": "哥哥……(///)", "actor": 206031, "actorName": "獨角獸 [小小的星之歌姬]", "nameColor": "#a9f548"}, {"say": "呼……謝謝……哥哥……能讓哥哥開心，獨角獸就滿足了……果然就像星塵姐姐說的那樣呢……", "actor": 206031, "actorName": "獨角獸 [小小的星之歌姬]", "nameColor": "#a9f548"}, {"say": "「小小的勇氣，就是最大的魔法」…嘻嘻…", "actor": 206031, "actorName": "獨角獸 [小小的星之歌姬]", "nameColor": "#a9f548"}]}}}