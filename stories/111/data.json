{"titles": {"CN": "小小的勇气", "EN": "Bits of Courage", "JP": "星の歌姫と小さな勇気", "KR": "스타더스트와 자그마한 용기 ", "TW": "小小的勇氣"}, "regions": {"CN": {"演唱会的门票": [{"sequence": ["小小的勇气&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">一  演唱会的门票</span><br>"]}, {"say": "某一天，港区", "narration": true}, {"say": "不知道指挥官…哥哥找独角兽有什么事…", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "不过…能见到哥哥…就好开心了…嘻嘻……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "几分钟后，港区指挥室", "narration": true}, {"say": "独角兽…报到…找独角兽有什么事情吗？哥哥？", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"bgName": "bg_story_star0"}, {"say": "这个是……？票？", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "演-唱-会？虽然不是很明白那是什么……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "（……）", "actor": 0, "actorName": "0", "nameColor": "#a9f548"}, {"say": "和哥哥……一起去？", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "难道……这就是传说中的……yue-hui？", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "嘻嘻……能和哥哥一起出去，独角兽……很期待……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}], "LIVE「平行四界」": [{"stopbgm": true, "sequence": ["小小的勇气&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">二  LIVE「平行四界」</span><br>"]}, {"say": "星尘演唱会现场", "narration": true}, {"bgm": "star", "bgName": "bg_story_star1", "say": "唔噢噢噢噢！星尘酱最棒了啊啊啊啊啊！！", "actorName": "观众A", "nameColor": "#a9f548"}, {"say": "星尘酱我们爱你啊啊啊啊！！！", "actorName": "观众B", "nameColor": "#a9f548"}, {"say": "哈啊……哈啊……", "actorName": "观众C", "nameColor": "#a9f548"}, {"say": "谢谢大家的应援～我已经感受到你们的感情了～让我们更加燃起来吧～！", "actorName": "星尘", "nameColor": "#a9f548"}, {"say": "哦噢噢噢噢！L！！O！！V！！E！！星•尘•酱！L！！O！！V！！E！！星•尘•酱！", "actorName": "台下众人", "nameColor": "#a9f548"}, {"say": "大、大家都好热情……哥、哥哥呢？", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "（！！！！！）", "actor": 0, "actorName": "0", "nameColor": "#a9f548"}, {"say": "哥哥……好兴奋的样子……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "好像……很开心……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "谢谢大家～星尘的歌～有没有传达到大家的心中呢～？让我们期待下一次再会吧！", "actorName": "星尘", "nameColor": "#a9f548"}, {"say": "哦噢噢噢噢哦噢噢噢噢！", "actorName": "台下众人", "nameColor": "#a9f548"}, {"say": "哈啊～～果然星尘酱是最棒的～", "actorName": "观众A", "nameColor": "#a9f548"}, {"say": "感觉……此生无憾了……", "actorName": "观众B", "nameColor": "#a9f548"}, {"say": "不行，我还要活着等到下次星尘酱的演唱会呢！", "actorName": "观众C", "nameColor": "#a9f548"}, {"say": "这就是……歌唱的力量吗……好厉害……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "感觉独角兽……都被感染了一样……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "独角兽也想……让哥哥那么开心……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}], "独角兽的烦恼": [{"sequence": ["小小的勇气&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">三  独角兽的烦恼</span><br>"]}, {"say": "几天后……", "narration": true}, {"say": "哈啊……独角兽……想不明白……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "那时候的哥哥……好像全身都散发着光芒一样……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "有种……输了的感觉……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "（猛摇头）嗯嗯，不对…独角兽只是…想要让指挥官……哥哥开心……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "哈啊……究竟怎么做……才能让哥哥……那么开心呢……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "星尘……姐姐吗？嗯……感觉那个姐姐身上……也散发着光芒呢……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "哥哥好像说过……“不耻下问”？", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "独角兽……要去问问那位姐姐……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}], "给星尘的信": [{"stopbgm": true, "sequence": ["小小的勇气&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">四  给星尘的信</span><br>"]}, {"bgName": "bg_story_star2"}], "星尘的回音": [{"stopbgm": true, "sequence": ["小小的勇气&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">五  星尘的回音</span><br>"]}, {"bgName": "bg_story_star3", "say": "“前略，亲爱的独角兽妹妹：”", "actorName": "星尘", "nameColor": "#a9f548"}, {"say": "“很高兴能收到你的来信，没想到能多了一个这么可爱的小小歌迷呢”", "actorName": "星尘", "nameColor": "#a9f548"}, {"say": "“从你的信里，可以充分感受到你的心意”", "actorName": "星尘", "nameColor": "#a9f548"}, {"say": "“独角兽真的很喜欢你的指挥官哥哥呀～”", "actorName": "星尘", "nameColor": "#a9f548"}, {"say": "“因为感情而苏醒的我说出来的话，肯定不会错的”", "actorName": "星尘", "nameColor": "#a9f548"}, {"say": "“对于这么可爱的独角兽妹妹，就让姐姐给你一点小小的建议吧”", "actorName": "星尘", "nameColor": "#a9f548"}, {"say": "“小小的勇气就是最大的魔法、哟”", "actorName": "星尘", "nameColor": "#a9f548"}, {"say": "“踏出一小步，让独角兽的哥哥看看不一样的你吧！”", "actorName": "星尘", "nameColor": "#a9f548"}, {"say": "“我会在这里为你加油的”", "actorName": "星尘", "nameColor": "#a9f548"}, {"say": "“为你应援的歌姬 星尘”", "actorName": "星尘", "nameColor": "#a9f548"}], "改变的勇气": [{"sequence": ["小小的勇气&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">六  改变的勇气</span><br>"]}, {"say": "怎、怎么办……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "虽然从星尘姐姐那里收到了这个……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "呜……果然还是好害羞……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "而且…这么华丽的衣服…独角兽…一定不合适的…要是哥哥不喜欢…怎么办…", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "小小的勇气……就是最大的魔法……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "嗯！独角兽，会加油的！", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}], "小小的魔法": [{"sequence": ["小小的勇气&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">七  小小的魔法</span><br>"]}, {"say": "哥、哥哥……在独角兽说可以之前，不可以睁开眼睛哦……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "呜…果然还是……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "星尘姐姐……给我勇气……", "actor": 206030, "actorName": "独角兽", "nameColor": "#a9f548"}, {"say": "（唱歌）……", "actor": 206031, "actorName": "独角兽 [小小的星之歌姬]", "nameColor": "#a9f548"}, {"say": "呼……怎、怎么样……星尘姐姐送的这套衣服……还有这首歌……", "actor": 206031, "actorName": "独角兽 [小小的星之歌姬]", "nameColor": "#a9f548"}, {"say": "星尘姐姐说这样……就能让哥哥开心……", "actor": 206031, "actorName": "独角兽 [小小的星之歌姬]", "nameColo