{"titles": {"CN": "珊瑚海首秀", "EN": "Battle of Coral Sea", "JP": "初陣！珊瑚海", "KR": "출전! 산호해", "TW": "珊瑚海首秀"}, "regions": {"CN": {"二章-珊瑚之海": [{"bgName": "bg_story_6", "say": "<span style=\"font-size: 0.700em;\">Stand your ground. Don't fire unless fired upon</span>\n<span style=\"font-size: 0.550em;\">坚守阵地。在敌人没有开枪射击以前，不要先开枪</span>", "actor": 107020, "actorName": "列克星敦", "nameColor": "#a9f548"}, {"say": "<span style=\"font-size: 0.700em;\">But if they mean to have a war</span>\n<span style=\"font-size: 0.550em;\">但是，如果敌人硬要把战争强加在我们头上</span>", "actor": 107020, "actorName": "列克星敦", "nameColor": "#a9f548"}, {"say": "<span style=\"font-size: 0.700em;\">Let it begin here! </span>\n<span style=\"font-size: 0.550em;\">那么，就让战争从这儿开始吧！</span>", "actor": 107020, "actorName": "列克星敦", "nameColor": "#a9f548"}, {"sequence": ["          第二章   珊瑚之海 <size=34.5>Coral Sea</size> &nbsp;&nbsp;&nbsp;&nbsp;<br>"]}], "二章-反击的序曲": [{"sequence": ["          不久前，西部某海域 &nbsp;&nbsp;&nbsp;&nbsp;<br>"]}, {"say": "无线电静默状态解除，企业紧急呼叫大黄蜂", "actor": 107060, "actorName": "企业", "nameColor": "#a9f548"}, {"say": "大黄蜂，收到", "actor": 107070, "actorName": "大黄蜂", "nameColor": "#a9f548"}, {"say": "我们的行踪被已被提前发现，判断任务是否可以继续执行", "actor": 107060, "actorName": "企业", "nameColor": "#a9f548"}, {"say": "虽然比预计的坐标还差了那么一点…但是我相信他们依然是可以做到的", "actor": 107070, "actorName": "大黄蜂", "nameColor": "#a9f548"}, {"say": "很好，立刻摧毁敌方的巡逻舰，其他所有护航舰队继续掩护大黄蜂，任务继续执行", "actor": 107060, "actorName": "企业", "nameColor": "#a9f548"}, {"say": "终于有机会让我大黄蜂大人一显身手了！", "actor": 107070, "actorName": "大黄蜂", "nameColor": "#a9f548"}, {"say": "是的，这么大胆的任务也只有你能办得到了（笑", "actor": 107060, "actorName": "企业", "nameColor": "#a9f548"}, {"bgName": "bg_story_7", "say": "为了所有在之前的偷袭中离去的姐妹，为了所有被战火点燃的国土海疆", "actor": 107070, "actorName": "大黄蜂", "nameColor": "#a9f548"}, {"say": "这一发满载悲愤与怒火的弓矢，将成为我们反击的序曲", "actor": 107070, "actorName": "大黄蜂", "nameColor": "#a9f548"}, {"say": "为了碧蓝色的自由意志", "actor": 107070, "actorName": "大黄蜂", "nameColor": "#a9f548"}, {"say": "B-25，杜立特中队，出击！", "actor": 107070, "actorName": "大黄蜂", "nameColor": "#a9f548"}], "二章-再下一城": [{"say": "唔…居然一兴奋就冲过头了…真是吾辈一生的失策…", "actor": 306050, "actorName": "祥凤", "nameColor": "#ff0000"}]}, "EN": {"Chapter 2: The Coral Sea": [{"bgName": "bg_story_6", "say": "<span style=\"font-size: 0.550em;\">Hold your positions! Don't fire unless fired upon!</span>", "actor": 107020, "actorName": "Lexington", "nameColor": "#a9f548"}, {"say": "<span style=\"font-size: 0.550em;\">But if they mean to have a war...</span>", "actor": 107020, "actorName": "Lexington", "nameColor": "#a9f548"}, {"say": "<span style=\"font-size: 0.550em;\">Let it begin!</span>", "actor": 107020, "actorName": "Lexington", "nameColor": "#a9f548"}, {"sequence": ["          Chapter 2 - <size=43.5>Battle of Coral Sea</size>  &nbsp;&nbsp;&nbsp;&nbsp;<br>"]}], "Chapter 2: Counterattack's Overture": [{"sequence": ["          Not long ago, in a western sea... &nbsp;&nbsp;&nbsp;&nbsp;<br>"]}, {"say": "Radio silence protocols have been lifted. Urgent call from Enterprise to Hornet!", "actor": 107060, "actorName": "Enterprise", "nameColor": "#a9f548"}, {"say": "Hornet here~! Go ahead!", "actor": 107070, "actorName": "Hornet", "nameColor": "#a9f548"}, {"say": "We've been found out. Should we continue our mission?", "actor": 107060, "actorName": "Enterprise", "nameColor": "#a9f548"}, {"say": "Coordinates were just a little off... but I think we can still do it!", "actor": 107070, "actorName": "Hornet", "nameColor": "#a9f548"}, {"say": "Very good. Immediately destroy the enemy's patrol ship! All convoys, continue to protect Hornet! The mission will continue.", "actor": 107060, "actorName": "Enterprise", "nameColor": "#a9f548"}, {"say": "It's finally time for me, Hornet, to show my stuff!", "actor": 107070, "actorName": "Hornet", "nameColor": "#a9f548"}, {"say": "Of course. Only you would be able to complete such a risky mission! Haha!", "actor": 107060, "actorName": "Enterprise", "nameColor": "#a9f548"}, {"bgName": "bg_story_7", "say": "Fight! Fight for our fallen sisters! Fight for the land and sea burned by the war!", "actor": 107070, "actorName": "Hornet", "nameColor": "#a9f548"}, {"say": "This attack is filled with anguish and fury. Now is when we make our stand!", "actor": 107070, "actorName": "Hornet", "nameColor": "#a9f548"}, {"say": "For the Eagles! For freedom!", "actor": 107070, "actorName": "Hornet", "nameColor": "#a9f548"}, {"say": "B-25 Doolittle Squadron, attack!", "actor": 107070, "actorName": "Hornet", "nameColor": "#a9f548"}], "Chapter 2: The Next City": [{"say": "I... I got overexcited... What a mistake...", "actor": 306050, "actorName": "Shouhou", "nameColor": "#ff0000"}]}, "JP": {"二章-珊瑚海": [{"bgName": "bg_story_6", "say": "<span style=\"font-size: 0.700em;\">「Stand your ground. Don't fire unless fired upon.</span>\n<span style=\"font-size: 0.550em;\">ーーそこに立っていろ。撃たれるまでは撃つな」</span>", "actor": 107020, "actorName": "レキシントン", "nameColor": "#a9f548"}, {"say": "<span style=\"font-size: 0.700em;\">「But if they mean to have a war.</span>\n<span style=\"font-size: 0.550em;\">ーー奴らが戦争をしたいというなら、」</span>", "actor": 107020, "actorName": "レキシントン", "nameColor": "#a9f548"}, {"say": "<span style=\"font-size: 0.700em;\">「Let it begin here! </span>\n<span style=\"font-size: 0.550em;\">ここで始めよう！」</span>", "actor": 107020, "actorName": "レキシントン", "nameColor": "#a9f548"}, {"sequence": ["          第二章   初陣！珊瑚海 <size=34.5>Coral Sea</size> &nbsp;&nbsp;&nbsp;&nbsp;<br>"]}], "二章-反撃の序曲": [{"sequence": ["          西部海域 &nbsp;&nbsp;&nbsp;&nbsp;<br>"]}, {"say": "無線封止解除。ホーネット、緊急連絡。", "actor": 107060, "actorName": "エンタープライズ", "nameColor": "#a9f548"}, {"say": "ホーネット、ガッチャ。", "actor": 107070, "actorName": "ホーネット", "nameColor": "#a9f548"}, {"say": "敵に発見されたようだ。これ以上任務継続するか決断を。", "actor": 107060, "actorName": "エンタープライズ", "nameColor": "#a9f548"}, {"say": "予定より少し早かったけど…この子たちならきっと出来るはず！", "actor": 107070, "actorName": "ホーネット", "nameColor": "#a9f548"}, {"say": "了解、敵のパトロールを掃討したのち、指揮官はホーネットを援護して任務継続を。", "actor": 107060, "actorName": "エンタープライズ", "nameColor": "#a9f548"}, {"say": "ようやく私の出番ってわけね！", "actor": 107070, "actorName": "ホーネット", "nameColor": "#a9f548"}, {"say": "そうだな。こんな大胆的な任務はあなたしか勤まらないもの。", "actor": 107060, "actorName": "エンタープライズ", "nameColor": "#a9f548"}, {"bgName": "bg_story_7", "say": "…ふぅ。奇襲で傷つけられた姉妹と、戦火に燃える我が祖国の為に、", "actor": 107070, "actorName": "ホーネット", "nameColor": "#a9f548"}, {"say": "怒りと悲しみを載せたこの一矢が、我が反撃の序曲とならん。", "actor": 107070, "actorName": "ホーネット", "nameColor": "#a9f548"}, {"say": "――この青き自由のために！", "actor": 107070, "actorName": "ホーネット", "nameColor": "#a9f548"}, {"say": "ドゥリットル隊、全機発進！", "actor": 107070, "actorName": "ホーネット", "nameColor": "#a9f548"}], "二章-次へ": [{"say": "吾輩としたことか突っ込み過ぎた……不覚や…", "actor": 306050, "actorName": "祥鳳", "nameColor": "#ff0000"}]}, "KR": {"2장 - 산호해": [{"bgName": "bg_story_6", "say": "<span style=\"font-size: 0.700em;\">\"Stand your ground. Don't fire unless fired upon.</span>\n<span style=\"font-size: 0.550em;\">──자리를 지키도록 해. 선제 사격은 금물이야.\"</span>", "actor": 107020, "actorName": "렉싱턴", "nameColor": "#92fc63"}, {"say": "<span style=\"font-size: 0.700em;\">\"But if they mean to have a war.</span>\n<span style=\"font-size: 0.550em;\">──다만, 저들이 전쟁을 하길 원한다면,\"</span>", "actor": 107020, "actorName": "렉싱턴", "nameColor": "#92fc63"}, {"say": "<span style=\"font-size: 0.700em;\">\"Let it begin here! </span>\n<span style=\"font-size: 0.550em;\">이 자리에서 시작해보자고!\"</span>", "actor": 107020, "actorName": "렉싱턴", "nameColor": "#92fc63"}, {"sequence": ["          제2장 출전! 산호해 <size=34.5>Coral Sea</size> &nbsp;&nbsp;&nbsp;&nbsp;<br>"]}], "2장 - 반격의 서곡": [{"sequence": ["          서부 해역 &nbsp;&nbsp;&nbsp;&nbsp;<br>"]}, {"say": "무선 차단 해제. 호넷을 긴급 호출.", "actor": 107060, "actorName": "엔터프라이즈", "nameColor": "#92fc63"}, {"say": "호넷, 수신.", "actor": 107070, "actorName": "호넷", "nameColor": "#92fc63"}, {"say": "적에게 발견된 모양이다. 이 이상 임무를 계속할지 판단 바람.", "actor": 107060, "actorName": "엔터프라이즈", "nameColor": "#92fc63"}, {"say": "예정보다 조금 빨랐지만... 이 아이들이라면 분명 할 수 있을 거야!", "actor": 107070, "actorName": "호넷", "nameColor": "#92fc63"}, {"say": "그래, 적의 순찰대를 소탕한 후, 지휘관은 호넷을 원호하며 임무를 계속할 수 있도록.", "actor": 107060, "actorName": "엔터프라이즈", "nameColor": "#92fc63"}, {"say": "이제야 내 차례가 온 거네!", "actor": 107070, "actorName": "호넷", "nameColor": "#92fc63"}, {"say": "그렇지. 이런 대담한 임무는 네가 아니면 수행해낼 수 없을 테니.", "actor": 107060, "actorName": "엔터프라이즈", "nameColor": "#92fc63"}, {"bgName": "bg_story_7", "say": "...후─. 기습에 의해 상처 입은 자매와, 전쟁의 업화에 휩싸인 조국을 위해 ", "actor": 107070, "actorName": "호넷", "nameColor": "#92fc63"}, {"say": "분노와 슬픔을 담은 이 한발이, 우리의 반격을 알리는 신호탄이 되리니.", "actor": 107070, "actorName": "호넷", "nameColor": "#92fc63"}, {"say": "────이 푸른 자유를 위해서!", "actor": 107070, "actorName": "호넷", "nameColor": "#92fc63"}, {"say": "둘리틀 편대, 전기 발함!", "actor": 107070, "actorName": "호넷", "nameColor": "#92fc63"}], "2장 - 다음으로": [{"say": "이 내가 깊이 파고들어버리다니...... 불찰이다...", "actor": 306050, "actorName": "쇼호", "nameColor": "#ff0000"}]}, "TW": {"二章-珊瑚之海": [{"bgName": "bg_story_6", "say": "<span style=\"font-size: 0.700em;\">Stand your ground. Don't fire unless fired upon</span>\n<span style=\"font-size: 0.550em;\">堅守陣地。在敵人沒有開槍射擊以前，不要先開槍</span>", "actor": 107020, "actorName": "列星頓", "nameColor": "#a9f548"}, {"say": "<span style=\"font-size: 0.700em;\">But if they mean to have a war</span>\n<span style=\"font-size: 0.550em;\">但是，如果敵人硬要把戰爭強加在我們頭上</span>", "actor": 107020, "actorName": "列星頓", "nameColor": "#a9f548"}, {"say": "<span style=\"font-size: 0.700em;\">Let it begin here! </span>\n<span style=\"font-size: 0.550em;\">那麼，就讓戰爭從這兒開始吧！</span>", "actor": 107020, "actorName": "列星頓", "nameColor": "#a9f548"}, {"sequence": ["          第二章   珊瑚之海 <span style=\"font-size: 0.567em;\">Coral Sea</span> &nbsp;&nbsp;&nbsp;&nbsp;<br>"]}], "二章-反擊的序曲": [{"sequence": ["          不久前，西部某海域 &nbsp;&nbsp;&nbsp;&nbsp;<br>"]}, {"say": "無線電靜默狀態解除，企業緊急呼叫大黃蜂", "actor": 107060, "actorName": "企業", "nameColor": "#a9f548"}, {"say": "大黃蜂，收到", "actor": 107070, "actorName": "大黃蜂", "nameColor": "#a9f548"}, {"say": "我們的行蹤被已被提前發現，判斷任務是否可以繼續執行", "actor": 107060, "actorName": "企業", "nameColor": "#a9f548"}, {"say": "雖然比預計的座標還差了那麼一點…但是我相信他們依然是可以做到的", "actor": 107070, "actorName": "大黃蜂", "nameColor": "#a9f548"}, {"say": "很好，立刻摧毀敵方的巡邏艦，其他所有護航艦隊繼續掩護大黃蜂，任務繼續執行", "actor": 107060, "actorName": "企業", "nameColor": "#a9f548"}, {"say": "終於有機會讓我大黃蜂大人一顯身手了！", "actor": 107070, "actorName": "大黃蜂", "nameColor": "#a9f548"}, {"say": "是的，這麼大膽的任務也只有妳能辦得到了（笑", "actor": 107060, "actorName": "企業", "nameColor": "#a9f548"}, {"bgName": "bg_story_7", "say": "為了所有在之前的偷襲中離去的姐妹，為了所有被戰火點燃的國土海疆", "actor": 107070, "actorName": "大黃蜂", "nameColor": "#a9f548"}, {"say": "這一發滿載悲憤與怒火的弓矢，將成為我們反擊的序曲", "actor": 107070, "actorName": "大黃蜂", "nameColor": "#a9f548"}, {"say": "為了碧藍色的自由意志", "actor": 107070, "actorName": "大黃蜂", "nameColor": "#a9f548"}, {"say": "B-25，杜立特中隊，出擊！", "actor": 107070, "actorName": "大黃蜂", "nameColor": "#a9f548"}], "二章-再下一城": [{"say": "唔…居然一興奮就沖過頭了…真是吾輩一生的失策…", "actor": 306050, "actorName": "祥鳳", "nameColor": "#ff0000"}]}}}