me": "扶桑", "nameColor": "#a9f548"}, {"say": "咿～這玩笑一點都不好笑啦…想想都覺得好冷呀…", "actorName": "山城", "nameColor": "#a9f548"}], "冬泳大會？": [{"sequence": ["冬日攻勢&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">二　冬泳大會？</span><br>"]}, {"say": "哈…哈啾！", "actorName": "山城", "nameColor": "#a9f548"}, {"say": "嗚…果然好冷啊外面…咦？前面的是？", "actorName": "山城", "nameColor": "#a9f548"}, {"say": "喲！這不是山城嗎，出來散步嗎？", "actorName": "日向", "nameColor": "#a9f548"}, {"say": "沒有啦…只是出來買點東西，嗚…好冷……", "actorName": "山城", "nameColor": "#a9f548"}, {"say": "不行啊山城～作為重櫻的一員，怎麼能被區區冷空氣打倒呢！", "actorName": "伊勢", "nameColor": "#a9f548"}, {"say": "日向、伊勢…妳們都好厲害啊～不覺得冷嗎？", "actorName": "山城", "nameColor": "#a9f548"}, {"say": "哼哼，寒冷這種東西，靠氣勢就能趕跑啦！", "actorName": "日向", "nameColor": "#a9f548"}, {"say": "我們還準備辦個冬泳大會呢！哼哼，把白鷹那些傢伙們也叫上，讓她們見識一下重櫻的氣魄！", "actorName": "伊勢", "nameColor": "#a9f548"}, {"say": "怎麼樣？山城妳也要一起參加嗎？", "actorName": "日向", "nameColor": "#a9f548"}, {"say": "嗚…我就……算了…哈…哈啾！", "actorName": "山城", "nameColor": "#a9f548"}], "遺失的禮物·上": [{"sequence": ["冬日攻勢&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">三 遺失的禮物·上</span><br>"]}, {"say": "冬泳…冬泳嗎…雖然說作為巫女…在冬天也會有需要用冰冷的清水潔淨身軀的時候……", "actorName": "山城", "nameColor": "#a9f548"}, {"say": "似乎最近…確實有些怠惰了呢……", "actorName": "山城", "nameColor": "#a9f548"}, {"say": "夏天時候的泳裝…指揮官送的…", "actorName": "山城", "nameColor": "#a9f548"}, {"say": "我記得是收在這裡了……", "actorName": "山城", "nameColor": "#a9f548"}, {"say": "咦？怎麼找不到了？", "actorName": "山城", "nameColor": "#a9f548"}], "遺失的禮物·下": [{"sequence": ["冬日攻勢&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">四 遺失的禮物·下</span><br>"]}, {"say": "嗚嗚…到底哪裡去了…", "actorName": "山城", "nameColor": "#a9f548"}, {"say": "嗯？妳在找什麼呢？翻箱倒櫃的", "actorName": "扶桑", "nameColor": "#a9f548"}, {"say": "嗚嗚…指揮官送的泳裝…找不到了啦……", "actorName": "山城", "nameColor": "#a9f548"}, {"say": "……", "actorName": "扶桑", "nameColor": "#a9f548"}, {"say": "唉，傻瓜，不是妳說的是指揮官送的非常重要的東西，所以就特地另外找了個櫃子收起來了嗎？", "actorName": "扶桑", "nameColor": "#a9f548"}, {"say": "這裡，找到啦", "actorName": "扶桑", "nameColor": "#a9f548"}, {"say": "哇！謝謝姐姐嗚嗚…", "actorN