{"titles": {"CN": "逸仙·羁绊"}, "regions": {"CN": {"羁绊·日常I": [{"say": "将军", "actor": 502010, "actorName": "逸仙"}, {"say": "……", "actor": 502020, "actorName": "宁海"}, {"say": "姐姐，我买包子回来了！今天有韭菜的有猪肉的，还有……", "actor": 502030, "actorName": "平海"}, {"say": "其实——", "actor": 502020, "actorName": "宁海"}, {"say": "发生什么了吗？啊！逸仙怎么一副理所当然的样子，拿我们的包子吃！", "actor": 502030, "actorName": "平海"}, {"say": "一个人吃还是有点多，来大家一起吃吧~", "actor": 502010, "actorName": "逸仙"}, {"say": "包子本来就是我们的！", "actor": 502030, "actorName": "平海"}, {"say": "那个……我……其实……在你出去的时候，包子就被我输光了", "actor": 502020, "actorName": "宁海"}, {"say": "你们是在下棋吗?", "actor": 502030, "actorName": "平海"}, {"say": "还是一次都没赢过的棋……", "actor": 502020, "actorName": "宁海"}, {"say": "宁海表现得也不错了，不必介怀", "actor": 502010, "actorName": "逸仙"}, {"say": "你这种平淡的语气才让我介怀呢！我的功夫刚好不擅长下棋而已，如果能换成别的就不一样了……", "actor": 502020, "actorName": "宁海"}, {"say": "比如？", "actor": 502010, "actorName": "逸仙"}, {"say": "训练的话，我可是很自信的！", "actor": 502020, "actorName": "宁海"}, {"sequence": ["滋……滋……<br>", " <br>", "■■系数检测……<br>", "<br>", "■■率：■■%<br>"]}], "羁绊·日常II": [{"say": "姐姐？你怎么又和逸仙在下棋呀？", "actor": 502030, "actorName": "平海"}, {"say": "果然还是棋类更适合我……", "actor": 502020, "actorName": "宁海"}, {"say": "可你上次不是说训练——", "actor": 502030, "actorName": "平海"}, {"say": "没有没有！棋类更好，棋类更好！", "actor": 502020, "actorName": "宁海"}, {"say": "呵呵，宁海表现得也不错了——", "actor": 502010, "actorName": "逸仙"}, {"say": "逸仙，专心下棋，别说多余的！", "actor": 502020, "actorName": "宁海"}, {"say": "我还是不太懂……姐姐，那为什么逸仙要蒙住眼？不是在下棋吗？", "actor": 502030, "actorName": "平海"}, {"say": "在特别的条件下对弈，也不失为一种别样的体验呢", "actor": 502010, "actorName": "逸仙"}, {"say": "可下棋的话，姐姐为什么两种棋都能动？", "actor": 502030, "actorName": "平海"}, {"say": "嘘！平海！别出声！", "actor": 502020, "actorName": "宁海"}, {"say": "其实…我也知道你在乱动棋盘…", "actor": 502010, "actorName": "逸仙"}, {"say": "骗人！你不是蒙住眼了吗！", "actor": 502020, "actorName": "宁海"}, {"say": "心中有棋局，自然不会发现不了这些小动作，不是吗？", "actor": 502010, "actorName": "逸仙"}, {"say": "比起这个，平海，是不是指挥官有任务下达？一定是这样，才让你来找我们的，对吧？", "actor": 502020, "actorName": "宁海"}, {"say": "用蹩脚的借口逃避可不值得赞扬哦？将军。好了，港区的事情就拜托你们了，指挥官那儿，我过去一趟就好", "actor": 502010, "actorName": "逸仙"}, {"say": "呜……", "actor": 502020, "actorName": "宁海"}, {"sequence": ["庄周梦蝶<br>", " <br>", "究竟是哲人梦见了蝴蝶？<br>", "抑或是蝴蝶梦见了哲人？<br>", "现实为何？虚拟为何？<br>", "“我”……是谁？<br>"]}], "羁绊·日常III": [{"say": "果然又是在和逸仙一起。姐姐最近怎么了？", "actor": 502030, "actorName": "平海"}, {"say": "我也有点感兴趣，宁海最近怎么老粘着我？", "actor": 502010, "actorName": "逸仙"}, {"say": "问题问反了！是逸仙最近都喜欢一个人待着！", "actor": 502020, "actorName": "宁海"}, {"say": "孑然一身，反而乐得清静，不是吗？", "actor": 502010, "actorName": "逸仙"}, {"say": "然后看海发呆看够一天吗", "actor": 502020, "actorName": "宁海"}, {"say": "也没什么不好吧？", "actor": 502010, "actorName": "逸仙"}, {"say": "那我跟着你，也是我的自由！哼！", "actor": 502020, "actorName": "宁海"}, {"say": "竟然被宁海担心了啊…总觉得有点感动，又有点心酸", "actor": 502010, "actorName": "逸仙"}, {"say": "心酸是什么意思啦心酸！？不过到头来，你到底在看什么东西？", "actor": 502020, "actorName": "宁海"}, {"say": "不知道", "actor": 502010, "actorName": "逸仙"}, {"say": "……哈啊？", "actor": 502020, "actorName": "宁海"}, {"say": "看着这片海，总觉得好像要想起什么了…然而最后又什么都想不到…", "actor": 502010, "actorName": "逸仙"}, {"say": "你就是待着不动才什么都想不到，一起去干点别的事情吧！", "actor": 502020, "actorName": "宁海"}, {"say": "嗯…那在这之前，将军。落子无悔，就算转移话题也没用哟～", "actor": 502010, "actorName": "逸仙"}, {"say": "呜呜呜……早晚有一天要赢回来……", "actor": 502020, "actorName": "宁海"}], "羁绊·日常IV": [{"say": "今天不看海了？", "actor": 502020, "actorName": "宁海"}, {"say": "与其待着什么都想不到，不如到实地感受一下，这，也是从你那里学到的呢", "actor": 502010, "actorName": "逸仙"}, {"say": "那我也——", "actor": 502020, "actorName": "宁海"}, {"say": "平海也要——", "actor": 502030, "actorName": "平海"}, {"say": "不行", "actor": 502010, "actorName": "逸仙"}, {"say": "我都还没说完呢……", "actor": 502020, "actorName": "宁海"}, {"say": "那片海域，毕竟不太平，若是因此让你们受伤，岂不是本末倒置", "actor": 502010, "actorName": "逸仙"}, {"say": "居然让逸仙担心了……”这句话原封不动地还你！", "actor": 502020, "actorName": "宁海"}, {"say": "……", "actor": 502010, "actorName": "逸仙"}, {"say": "正因为不太平，我才要跟着去！", "actor": 502020, "actorName": "宁海"}, {"say": "平海也是！", "actor": 502030, "actorName": "平海"}, {"say": "那，至少也得先准备万全", "actor": 502010, "actorName": "逸仙"}, {"sequence": ["滋……滋……<br>", " <br>", "■■率：6■.■%<br>"]}], "羁绊·勿忘I": [{"say": "终于要出发了!", "actor": 502020, "actorName": "宁海"}, {"say": "嗯！", "actor": 502030, "actorName": "平海"}, {"say": "这可不是去远足呢", "actor": 502010, "actorName": "逸仙"}, {"say": "我知道。不过，你究竟想在那片海找到什么？", "actor": 502020, "actorName": "宁海"}, {"say": "谁知道呢，也许是回忆？", "actor": 502010, "actorName": "逸仙"}, {"say": "回忆？", "actor": 502020, "actorName": "宁海"}, {"say": "逸仙忘掉了什么吗？", "actor": 502030, "actorName": "平海"}, {"say": "只是有一种感觉，有那么一段很重要的回忆，被我弄丢了……", "actor": 502010, "actorName": "逸仙"}, {"sequence": ["回忆<br>", "似乎忘记了非常重要的事情<br>", "悲伤的往事<br>", "不能忘记，勿忘■■<br>", "“我”……忘记了什么？<br>"]}], "羁绊·勿忘II": [{"say": "逸仙真是意外的可靠！", "actor": 502020, "actorName": "宁海"}, {"say": "就和姐姐一样强！", "actor": 502030, "actorName": "平海"}, {"say": "意外是多余的", "actor": 502010, "actorName": "逸仙"}, {"say": "（远眺）……你们…不如就这样回去吧？", "actor": 502010, "actorName": "逸仙"}, {"say": "你都感觉前面有危险，还觉得我会答应？", "actor": 502020, "actorName": "宁海"}, {"say": "逸仙担心我们会受伤吗？", "actor": 502030, "actorName": "平海"}, {"say": "如果你们出了什么意外，我会很难办的", "actor": 502010, "actorName": "逸仙"}, {"say": "是感受到姐姐的魅力了？", "actor": 502020, "actorName": "宁海"}, {"say": "毕竟还有三个月分量的包子呢……", "actor": 502010, "actorName": "逸仙"}, {"say": "喂！", "actor": 502020, "actorName": "宁海"}, {"sequence": ["熟悉的风景，熟悉的气息<br>", "<br>", "对了，“我”是……我和她们是……<br>"]}], "羁绊·勿忘III": [{"say": "是因为回忆的复苏吗，和你们一起的时光，居然也能让我感觉弥足珍贵……", "actor": 502010, "actorName": "逸仙"}, {"say": "不是理所当然的吗……只是，我的内心仍在雀跃不已", "actor": 502010, "actorName": "逸仙"}, {"say": "还差一步，最后的一步，将军的一步", "actor": 502010, "actorName": "逸仙"}, {"say": "就算知道你们在等候，我也想继续前进", "actor": 502010, "actorName": "逸仙"}, {"say": "谢谢你们陪伴着我，宁海，平海", "actor": 502010, "actorName": "逸仙"}, {"say": "只是，在这片海域的尽头，在我的终点的，是——", "actor": 502010, "actorName": "逸仙"}, {"sequence": ["滋……滋……<br>", " <br>", "■■率：1■■.■%<br>", "■■完成，■■进程可选<br>", "是否■■？是否■■？是否■■？<br>"]}], "羁绊·觉醒": [{"say": "过了今天，逸仙就算正式加入我们了，得好好吃一顿包子来欢迎欢迎！", "actor": 502020, "actorName": "宁海"}, {"say": "姐姐，我也要来！", "actor": 502030, "actorName": "平海"}, {"say": "……", "actor": 502010, "actorName": "逸仙"}, {"say": "怎么？太过于感动而说不出话了？", "actor": 502020, "actorName": "宁海"}, {"say": "哇！逸仙居然笑得这么开心！", "actor": 502030, "actorName": "平海"}, {"say": "……是吗？和你们待在一起，感觉也不坏。今天的包子就让我来请客吧", "actor": 502010, "actorName": "逸仙"}, {"say": "真的？突然有点过意不去呢……", "actor": 502020, "actorName": "宁海"}, {"say": "宁海还欠我三个月的包子，扣掉一天，还剩两个月零三十天", "actor": 502010, "actorName": "逸仙"}, {"say": "啊！我就知道！", "actor": 502020, "actorName": "宁海"}, {"say": "觉醒的条件果然如想象的那样简单，只要在特定的时间点进行适量的刺激…呵呵呵", "actorName": "观察者", "nameColor": "#D6341D"}, {"say": "这一次不对“她们”进行销毁么？", "actorName": "测试者", "nameColor": "#D6341D"}, {"say": "关键的数据已经到手了，而且，她们日后的表现也应该纳入观测的范围", "actorName": "观察者", "nameColor": "#D6341D"}, {"say": "啊啊啊，这样的话多无聊啊，都没有我出马的机会了！！", "actorName": "？？？", "nameColor": "#D6341D"}, {"say": "放心~很快就会有新的指令传递给你了~", "actorName": "观察者", "nameColor": "#D6341D"}, {"say": "在那之前，我们下一个观测的目标会是谁呢？真令人期待呢呵呵呵~", "actorName": "观察者", "nameColor": "#D6341D"}]}}}