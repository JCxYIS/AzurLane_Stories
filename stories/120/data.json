or": "#a9f548"}, {"say": "Buli! Dadadadadadah! I'm running in circles~ Just another normal day at the base!", "actor": 100010, "actorName": "Prototype Bulin MKII", "nameColor": "#a9f548"}, {"say": "Buli! You look hyped, buli! But I'm gonna be even more hyped, buli!", "actor": 100000, "actorName": "Universal Bulin", "nameColor": "#a9f548"}, {"say": "W-who are they...?!", "actor": 501030, "actorName": "Chang Chun", "nameColor": "#a9f548"}, {"say": "Aren't they one of those \"Seven Wonders of The Base,\" the Bulins?!", "actor": 501020, "actorName": "Fu Shun", "nameColor": "#a9f548"}, {"say": "It's rumored that seeing a Bulin brings you luck for the rest of the day!", "actor": 501040, "actorName": "Tai Yuan", "nameColor": "#a9f548"}, {"say": "Where did that urban legend come from...", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "I think we're out of paint again...", "actor": 501030, "actorName": "Chang Chun", "nameColor": "#a9f548"}, {"say": "Okay! I'll go look for some more!", "actor": 501020, "actorName": "Fu Shun", "nameColor": "#a9f548"}, {"say": "I bet you just want to chase after the Bulins...", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "Nuh-uh, no way! I just happen to feel like running around a bit! I'll go find the Buli... I mean, some paint!", "actor": 501020, "actorName": "Fu Shun", "nameColor": "#a9f548"}], "Time for a (Lunch) Break": [{"stopbgm": true, "sequence": ["An Shan's Coloring Book&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">Chapter 3 - Time For a (Lunch) Break</span><br>"]}, {"bgm": "story-china", "bgName": "bg_story_school", "say": "I'm back, guys! I couldn't get a hold of the Bulins... but I brought some other people with me!", "actor": 501020, "actorName": "Fu Shun", "nameColor": "#a9f548"}, {"say": "Oh! Why, if it isn't Ning Hai and Ping Hai!", "actor": 501040, "actorName": "Tai Yuan", "nameColor": "#a9f548"}, {"say": "Fu Shun said you guys are up to something fun.", "actor": 502020, "actorName": "Ning Hai", "nameColor": "#a9f548"}, {"say": "I want to have some fun too~", "actor": 502030, "actorName": "Ping Hai", "nameColor": "#a9f548"}, {"say": "Fu Shun! Didn't I tell you not to cause trouble for people?!", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "Ahahahah... You're as dead-serious as usual, An Shan.", "actor": 502020, "actorName": "Ning Hai", "nameColor": "#a9f548"}, {"say": "I brought some meat buns Yat Sen made. Wanna eat some with us?", "actor": 502030, "actorName": "Ping Hai", "nameColor": "#a9f548"}, {"say": "Of course!", "actorName": "Tai Yuan & Chang Chun & An Shan", "nameColor": "#a9f548"}, {"say": "Yat Sen's meat buns are the best...", "actor": 501040, "actorName": "Tai Yuan", "nameColor": "#a9f548"}, {"say": "Mmm~ Sho goooowd~", "actor": 501030, "actorName": "Chang Chun", "nameColor": "#a9f548"}, {"say": "Yat Sen never disappoints with her amazing cooking... Mmm, it's delicious~!", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "Heheheh, thanks~", "actor": 502030, "actorName": "Ping Hai", "nameColor": "#a9f548"}, {"say": "She wasn't complimenting YOU, Ping.", "actor": 502020, "actorName": "Ning Hai", "nameColor": "#a9f548"}, {"say": "Hey... I feel like we're forgetting something...", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "Fu Shun said you guys are up to something fun, is that what...?", "actor": 502030, "actorName": "Ping Hai", "nameColor": "#a9f548"}, {"say": "Oh, right! We were filling in this coloring book!", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}], "Drawing Together": [{"stopbgm": true, "sequence": ["An Shan's Coloring Book&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">Chapter 4 - Drawing Together</span><br>"]}, {"bgm": "story-china", "bgName": "bg_story_school", "say": "With all of us together like this... I think we're causing a lot of noise.", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "It's fine, no big deal! They say the more, the merrier, right?", "actor": 501020, "actorName": "Fu Shun", "nameColor": "#a9f548"}, {"say": "I'll color this part~", "actor": 502030, "actorName": "Ping Hai", "nameColor": "#a9f548"}, {"say": "Ping and Fu Shun play together like they're on the same wavelength...", "actor": 502020, "actorName": "Ning Hai", "nameColor": "#a9f548"}, {"say": "Ning... Let me say I'm sorry for Fu Shun causing you so much trouble...", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "An Shan, if you worry so much all the time, you'll develop wrinkles on your face.", "actor": 501020, "actorName": "Fu Shun", "nameColor": "#a9f548"}, {"say": "Sigh... And who do you think is making me worry so much in the first place...", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "Ahahah, you must have it really tough, An Shan.", "actor": 502020, "actorName": "Ning Hai", "nameColor": "#a9f548"}, {"say": "But still, we should let everyone enjoy themselves and not fuss over the details, okay?", "actor": 502020, "actorName": "Ning Hai", "nameColor": "#a9f548"}, {"say": "Ahahaha... You're totally right, Ning.", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "Alright, I'll join in! Let me handle this part!", "actor": 502020, "actorName": "Ning Hai", "nameColor": "#a9f548"}, {"say": "O-okay... I'll join in, too!", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}], "An Shan's Drawing Book": [{"stopbgm": true, "sequence": ["An Shan's Coloring Book&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">Chapter 5 - An Shan's Drawing Book</span><br>"]}, {"bgm": "story-china", "bgName": "bg_story_school", "say": "Let's see... Let's color this part with...", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "The last drawing is finished!", "actorName": "Fu Shun & Chang Chun & Tai Yuan", "nameColor": "#a9f548"}, {"say": "Hooray!", "actorName": "Ning Hai & Ping Hai", "nameColor": "#a9f548"}, {"say": "It took some time... but it's finally done!", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "And we couldn't have done it without everyone's help! Ahh...", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "...I think An Shan got more into it than anyone else in the end...", "actor": 501030, "actorName": "Chang Chun", "nameColor": "#a9f548"}, {"say": "Ahahahah! That's what I like so much about her!", "actor": 501020, "actorName": "Fu Shun", "nameColor": "#a9f548"}, {"say": "She's... cute... when she does that...", "actor": 501040, "actorName": "Tai Yuan", "nameColor": "#a9f548"}, {"say": "A-ahem! I was only wrapping things up, like a big sister should!", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "Ahahah. It's always such fun to hang out with you all.", "actor": 502020, "actorName": "Ning Hai", "nameColor": "#a9f548"}, {"say": "Yeah. Playing together with you was a lot of fun...", "actor": 502030, "actorName": "Ping Hai", "nameColor": "#a9f548"}, {"say": "Ah, so this is where you've all been.", "actor": 502010, "actorName": "Yat Sen", "nameColor": "#a9f548"}, {"say": "Yat Sen?! Why are you here?", "actor": 502020, "actorName": "Ning Hai", "nameColor": "#a9f548"}, {"say": "Oh, hello, Yat Sen!", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "Look at this drawing book! We just finished with it!", "actor": 501020, "actorName": "Fu Shun", "nameColor": "#a9f548"}, {"say": "All we really did was color it, though...", "actor": 501030, "actorName": "Chang Chun", "nameColor": "#a9f548"}, {"say": "Ah, did you? May I have a look? ...My, what wonderful drawings.", "actor": 502010, "actorName": "Yat Sen", "nameColor": "#a9f548"}, {"say": "Eheheh...", "actor": 501040, "actorName": "Tai Yuan", "nameColor": "#a9f548"}, {"say": "Hm, what's this? There's an empty page on the back...", "actor": 502010, "actorName": "Yat Sen", "nameColor": "#a9f548"}, {"say": "Huh?!", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "It's completely blank... But since this is a drawing book, I suppose that's how it is supposed to look like...", "actor": 502010, "actorName": "Yat Sen", "nameColor": "#a9f548"}, {"say": "So basically... we can draw whatever we want on it?", "actor": 501020, "actorName": "Fu Shun", "nameColor": "#a9f548"}, {"say": "In that case, we should give it to An Shan!", "actor": 501030, "actorName": "Chang Chun", "nameColor": "#a9f548"}, {"say": "What? T-to me?", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "We know you have it in you to draw a wonderful picture.", "actor": 501040, "actorName": "Tai Yuan", "nameColor": "#a9f548"}, {"say": "Well, if you think I can, then...", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}, {"say": "Heh, you look really happy, An Shan!", "actor": 501020, "actorName": "Fu Shun", "nameColor": "#a9f548"}, {"say": "Well, there's no need to rush it. First, why don't we enjoy some food I brought with me?", "actor": 502010, "actorName": "Yat Sen", "nameColor": "#a9f548"}, {"say": "Heck yeah!", "actorName": "Everyone", "nameColor": "#a9f548"}, {"say": "Okay, then after that, I'll take my time and draw something... Hehehe...", "actor": 501010, "actorName": "An Shan", "nameColor": "#a9f548"}]}, "JP": {"古倉庫の掘り出し物": [{"stopbgm": true, "sequence": ["四天王の大冒険・鞍山編&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">その一　古倉庫の掘り出し物</span><br>"]}, {"bgm": "story-china", "bgName": "bg_story_school", "say": "鞍山（アンシャン）級の～", "actor": 501020, "actorName": "撫順", "nameColor": "#a9f548"}, {"say": "おえかき教室～～～", "actor": 501030, "actorName": "長春", "nameColor": "#a9f548"}, {"say": "は、始まるよっ！", "actor": 501040, "actorName": "太原", "nameColor": "#a9f548"}, {"say": "何やっているの…", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}, {"say": "まあ、なんというか～成り行きで？", "actor": 501020, "actorName": "撫順", "nameColor": "#a9f548"}, {"say": "実は太原（タイゲン）ちゃんが倉庫を漁っていたらこんなのが出てきたよ", "actor": 501030, "actorName": "長春", "nameColor": "#a9f548"}, {"say": "え、えへへへ…", "actor": 501040, "actorName": "太原", "nameColor": "#a9f548"}, {"say": "倉庫…？", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}, {"say": "いや～な、なんでもないよ！それよりこのおえかき帳を見てよ！", "actor": 501020, "actorName": "撫順", "nameColor": "#a9f548"}, {"say": "おえかき帳というより、半分ぬりえだよねこれ…", "actor": 501030, "actorName": "長春", "nameColor": "#a9f548"}, {"say": "ジャジャーン、じゃあさ、みんなでやってみよ！", "actor": 501020, "actorName": "撫順", "nameColor": "#a9f548"}, {"say": "撫順（ブジュン）…また始まった…", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}, {"say": "わ、わたしもやりたいです…", "actor": 501040, "actorName": "太原", "nameColor": "#a9f548"}, {"say": "まあ、外でトラブル起こすよりマシだけどね…", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}, {"say": "でもぬりえやると言っても、絵の具はないよね…", "actor": 501030, "actorName": "長春", "nameColor": "#a9f548"}, {"say": "よぉし、絵の具を集めるぞー", "actor": 501020, "actorName": "撫順", "nameColor": "#a9f548"}, {"say": "人に迷惑かけたらダメよ！", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}], "母港の不思議": [{"stopbgm": true, "sequence": ["四天王の大冒険・鞍山編&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">その二　母港の不思議</span><br>"]}, {"bgm": "story-china", "bgName": "bg_story_school", "say": "ここはこう…", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}, {"say": "あとここはこうですね…", "actor": 501040, "actorName": "太原", "nameColor": "#a9f548"}, {"say": "ここはこうしよう！", "actor": 501020, "actorName": "撫順", "nameColor": "#a9f548"}, {"say": "ああ！撫順姉さんまた間違えてますよ！", "actor": 501030, "actorName": "長春", "nameColor": "#a9f548"}, {"say": "まあまあ、適当でいいじゃない～これぐらい問題ないって～", "actor": 501020, "actorName": "撫順", "nameColor": "#a9f548"}, {"say": "もうわけがわからないよ…", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}, {"say": "プリン！アダダダダダ！走り回るよ～母港戦線、今日も異常なし！", "actor": 100010, "actorName": "試作型ブリMKII", "nameColor": "#a9f548"}, {"say": "プリン！今日も姉ちゃんが元気プリン！でもブリちゃんも負けないプリン！", "actor": 100000, "actorName": "汎用型ブリ", "nameColor": "#a9f548"}, {"say": "あ、あれは…！？", "actor": 501030, "actorName": "長春", "nameColor": "#a9f548"}, {"say": "「母港の不思議」のひとつ、ブリちゃん！？", "actor": 501020, "actorName": "撫順", "nameColor": "#a9f548"}, {"say": "ブリちゃんを見たら一日中幸運になると噂されていますね！", "actor": 501040, "actorName": "太原", "nameColor": "#a9f548"}, {"say": "そんな都市伝説どこから来たのよ…", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}, {"say": "絵の具、また足りなくなったよね…", "actor": 501030, "actorName": "長春", "nameColor": "#a9f548"}, {"say": "よし！今度は私が補充しに行くよ！", "actor": 501020, "actorName": "撫順", "nameColor": "#a9f548"}, {"say": "ブリちゃんをおっかけたいだけでしょう…", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}, {"say": "いやいや、そんなことないよ～たまたま外で走りたくなっちゃって～ブリ…じゃなくて絵の具！今迎えにいくよー！", "actor": 501020, "actorName": "撫順", "nameColor": "#a9f548"}], "東煌の（バオズ）ススメ": [{"stopbgm": true, "sequence": ["四天王の大冒険・鞍山編&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">その三　東煌の（バオズ）ススメ</span><br>"]}, {"bgm": "story-china", "bgName": "bg_story_school", "say": "たっだいまーブリちゃんたちは捕まえられなかったけど…ほかの人を連れてきたよ！", "actor": 501020, "actorName": "撫順", "nameColor": "#a9f548"}, {"say": "あ！平海さんと寧海さん！", "actor": 501040, "actorName": "太原", "nameColor": "#a9f548"}, {"say": "撫順がみんなで面白いことやってるって", "actor": 502020, "actorName": "寧海", "nameColor": "#a9f548"}, {"say": "平海も参加したい～", "actor": 502030, "actorName": "平海", "nameColor": "#a9f548"}, {"say": "撫順！先輩たちにメイワクをかけたらダメでしょう？！", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}, {"say": "あははは…鞍山（アンシャン）は相変わらず真面目ね。", "actor": 502020, "actorName": "寧海", "nameColor": "#a9f548"}, {"say": "逸仙姉が作ったバオズを持ってきた。一緒に食べよ？", "actor": 502030, "actorName": "平海", "nameColor": "#a9f548"}, {"say": "おおお！", "actorName": "太原&長春&鞍山", "nameColor": "#a9f548"}, {"say": "逸仙さんの作ったバオズ、美味しいですね…", "actor": 501040, "actorName": "太原", "nameColor": "#a9f548"}, {"say": "ん~ま～い～", "actor": 501030, "actorName": "長春", "nameColor": "#a9f548"}, {"say": "逸仙さんの料理の腕は相変わらず凄いね…おいしぃ～！！", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}, {"say": "へへへ～", "actor": 502030, "actorName": "平海", "nameColor": "#a9f548"}, {"say": "あんたのことを褒めていないわよ？", "actor": 502020, "actorName": "寧海", "nameColor": "#a9f548"}, {"say": "でも…なにかを忘れていたような…", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}, {"say": "鞍山たちがなにか面白いことをやっているんじゃなかった…？", "actor": 502030, "actorName": "平海", "nameColor": "#a9f548"}, {"say": "あ！そうだ！おえかき帳だ！", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}], "みんなのおえかき帳": [{"stopbgm": true, "sequence": ["四天王の大冒険・鞍山編&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">その四　みんなのおえかき帳</span><br>"]}, {"bgm": "story-china", "bgName": "bg_story_school", "say": "なんか…騒がしくなってきたのね。", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}, {"say": "いいよいいよ、人が多いほうが楽しいじゃん～", "actor": 501020, "actorName": "撫順", "nameColor": "#a9f548"}, {"say": "平海がここを塗るよ～", "actor": 502030, "actorName": "平海", "nameColor": "#a9f548"}, {"say": "平海って撫順とすごく相性がいいね。", "actor": 502020, "actorName": "寧海", "nameColor": "#a9f548"}, {"say": "すみません…寧海さん、うちの撫順がメイワクをかけちゃって…", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}, {"say": "鞍山姉さん、心配しすぎると顔にシワが出ちゃうよ？", "actor": 501020, "actorName": "撫順", "nameColor": "#a9f548"}, {"say": "はあ…誰のせいでいつも心配してると思っているのよ…", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}, {"say": "うふふ、鞍山も大変ね。", "actor": 502020, "actorName": "寧海", "nameColor": "#a9f548"}, {"say": "せっかくみんな楽しくやっているし、細かいことはいいんじゃない？", "actor": 502020, "actorName": "寧海", "nameColor": "#a9f548"}, {"say": "あははは…寧海さんの言うとおりです…", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}, {"say": "よーし！私もやるわ！ここは私に任せなさい！", "actor": 502020, "actorName": "寧海", "nameColor": "#a9f548"}, {"say": "じゃ、じゃあ…私も――！", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}], "鞍山のおえかき帳": [{"stopbgm": true, "sequence": ["四天王の大冒険・鞍山編&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">その五　鞍山のおえかき帳</span><br>"]}, {"bgm": "story-china", "bgName": "bg_story_school", "say": "うん…じゃあ次はこうして――", "actor": 501010, "actorName": "鞍山", "nameColor": "#a9f548"}, {"say": "最後の絵が完成した！", "actorN