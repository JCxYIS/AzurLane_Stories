{"titles": {"CN": "春天的赏樱大会", "EN": "Flower Festival", "JP": "春のお花見大会", "KR": "벚꽃놀이 대소동 ", "TW": "春天的賞櫻大會"}, "regions": {"CN": {"春日和": [{"stopbgm": true, "sequence": ["春天的赏樱大会&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">一  春日和</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_room", "say": "呼…不知不觉，天气开始转暖了呢", "actor": 307030, "actorName": "苍龙", "nameColor": "#a9f548"}, {"say": "是的呢，毕竟也差不多是春天了", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "时间过得真快啊…", "actor": 307030, "actorName": "苍龙", "nameColor": "#a9f548"}, {"say": "是的呢，来，喝杯茶吧", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "噢，谢谢…——呜哇！凤、凤翔！？什么时候开始在这里的…", "actor": 307030, "actorName": "苍龙", "nameColor": "#a9f548"}, {"say": "哇！凤翔手脚这么快啊！", "actor": 307040, "actorName": "飞龙", "nameColor": "#a9f548"}, {"say": "刚在准备泡茶的时候遇到了凤翔，就请她帮了点忙", "actor": 307040, "actorName": "飞龙", "nameColor": "#a9f548"}, {"say": "原、原来如此…", "actor": 307030, "actorName": "苍龙", "nameColor": "#a9f548"}, {"say": "呵呵…一点小事～", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "不过春天啊…樱花也差不多要开了呢", "actor": 307030, "actorName": "苍龙", "nameColor": "#a9f548"}, {"say": "（微笑）", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "那就…来开宴会吧～", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "说到春天就是赏樱大会了吧～", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "哦哦！来开吧来开吧！", "actor": 307040, "actorName": "飞龙", "nameColor": "#a9f548"}, {"say": "…倒是个好主意，不过你们还真有热情呢…", "actor": 307030, "actorName": "苍龙", "nameColor": "#a9f548"}, {"say": "这就是所谓的“女子会”吗？好嘞！", "actor": 307040, "actorName": "飞龙", "nameColor": "#a9f548"}, {"say": "不，我想应该不是你想的那种…", "actor": 307030, "actorName": "苍龙", "nameColor": "#a9f548"}, {"say": "准备就交给我吧～", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}], "邀约": [{"stopbgm": true, "sequence": ["春天的赏樱大会&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">二  邀约</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "那我就去邀请一下大家吧", "actor": 307030, "actorName": "苍龙", "nameColor": "#a9f548"}, {"say": "啊啦，翔鹤和瑞鹤，来得正好", "actor": 307030, "actorName": "苍龙", "nameColor": "#a9f548"}, {"say": "嗯？", "actorName": "翔鹤&瑞鹤", "nameColor": "#a9f548"}, {"say": "原来是苍龙啊…", "actor": 307050, "actorName": "翔鹤", "nameColor": "#a9f548"}, {"say": "啊哈哈…突然叫住你们不好意思，只是想问问你们要不要一起来赏樱花而已", "actor": 307030, "actorName": "苍龙", "nameColor": "#a9f548"}, {"say": "赏樱大会？", "actor": 307060, "actorName": "瑞鹤", "nameColor": "#a9f548"}, {"say": "也是，又到春天了呢…", "actor": 307050, "actorName": "翔鹤", "nameColor": "#a9f548"}, {"say": "还有凤翔准备的美味食物哦", "actor": 307030, "actorName": "苍龙", "nameColor": "#a9f548"}, {"say": "请务必让我们参加！", "actor": 307060, "actorName": "瑞鹤", "nameColor": "#a9f548"}, {"say": "瑞鹤…姐姐开始担心你未来会不会被人骗了", "actor": 307050, "actorName": "翔鹤", "nameColor": "#a9f548"}, {"say": "如月也想参加宴会……", "actor": 301330, "actorName": "如月", "nameColor": "#a9f548"}, {"say": "有糖吃吗？睦月也要吃糖！", "actor": 301320, "actorName": "睦月", "nameColor": "#a9f548"}, {"say": "吃太多甜食对身体可不好哦", "actor": 307030, "actorName": "苍龙", "nameColor": "#a9f548"}, {"say": "让人忍不住想叫一声苍龙老师呢…", "actor": 307050, "actorName": "翔鹤", "nameColor": "#a9f548"}], "祭典的准备": [{"stopbgm": true, "sequence": ["春天的赏樱大会&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">三  祭典的准备</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "好～那就开始准备吧～", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "一个人忙不过来的吧！看看我带了些谁来～", "actor": 307040, "actorName": "飞龙", "nameColor": "#a9f548"}, {"say": "哎呀呀，这是", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "请让我也帮点忙吧～", "actor": 301310, "actorName": "松风", "nameColor": "#a9f548"}, {"say": "料理吗…虽然做不出很华丽的东西，帮忙做点平常的料理还是可以的～", "actor": 302040, "actorName": "长良", "nameColor": "#a9f548"}, {"say": "我们也来帮忙了～", "actor": 305010, "actorName": "扶桑", "nameColor": "#a9f548"}, {"say": "赏樱大会呀，真是期待呢～", "actor": 305020, "actorName": "山城", "nameColor": "#a9f548"}, {"say": "哎呀呀，真是热闹呢", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "我说到赏樱大会，大家就主动过来帮忙了呢～", "actor": 307040, "actorName": "飞龙", "nameColor": "#a9f548"}, {"say": "看来大家都对赏樱大会很期待呀～", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "好～那就来做出不辜负大家期待的赏樱料理吧～", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}], "宴会开幕": [{"stopbgm": true, "sequence": ["春天的赏樱大会&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">四  宴会开幕</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "那么～赏樱大会～开始咯～", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "噢！！", "actorName": "众人", "nameColor": "#a9f548"}, {"say": "呵呵，这边准备了非常多的料理哟，尽情享受吧～", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "翔鹤姐～这个天妇罗好好吃～", "actor": 307060, "actorName": "瑞鹤", "nameColor": "#a9f548"}, {"say": "是是…——", "actor": 307050, "actorName": "翔鹤", "nameColor": "#a9f548"}, {"say": "原来如此！大家聚在一起大吃大喝就是所谓的“赏樱大会”啊！", "actor": 301110, "actorName": "雷", "nameColor": "#a9f548"}, {"say": "我想应该不是这样的…", "actor": 301130, "actorName": "白露", "nameColor": "#a9f548"}, {"say": "呒…菠萝包，好吃…", "actor": 302010, "actorName": "夕张", "nameColor": "#a9f548"}, {"say": "哈欠～天气好得让人想要睡一觉了呢…", "actor": 301200, "actorName": "野分", "nameColor": "#a9f548"}, {"say": "话说晓呢？怎么没跟你们一起来", "actor": 301200, "actorName": "野分", "nameColor": "#a9f548"}, {"say": "晓姐姐…留下了“我去买点赏樱时可以吃的零食”的字条就出门了（远目", "actor": 301120, "actorName": "电", "nameColor": "#a9f548"}, {"say": "那大约…是三天前的事情了（远目", "actor": 301110, "actorName": "雷", "nameColor": "#a9f548"}, {"say": "……", "actorName": "众人", "nameColor": "#a9f548"}], "花与幕": [{"stopbgm": true, "sequence": ["春天的赏樱大会&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">五  樱与幕</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "果然说到春天，就少不了樱花呢", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "呵呵，不论什么时候，举办宴会总是让人感到开心呢", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "辛苦凤翔准备了～", "actor": 307030, "actorName": "苍龙", "nameColor": "#a9f548"}, {"say": "看到大家那么开心，就觉得值得了呢，恩？那边是——", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "这边就是会场吗？哇，好热闹！", "actor": 401230, "actorName": "Z23", "nameColor": "#a9f548"}, {"say": "我闻到美食的味道了～", "actor": 201210, "actorName": "标枪", "nameColor": "#a9f548"}, {"say": "酒香…", "actor": 101170, "actorName": "拉菲", "nameColor": "#a9f548"}, {"say": "重樱春季特产——“赏樱大会”…大家一起才好", "actor": 301050, "actorName": "绫波", "nameColor": "#a9f548"}, {"say": "谢谢绫波的邀请～", "actor": 401230, "actorName": "Z23", "nameColor": "#a9f548"}, {"say": "啊，那边还有位置，我们快过去吧～", "actor": 201210, "actorName": "标枪", "nameColor": "#a9f548"}, {"say": "酒…的香气——", "actor": 101170, "actorName": "拉菲", "nameColor": "#a9f548"}, {"say": "真是让人会心一笑的场景呢～", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}], "花见酒": [{"stopbgm": true, "sequence": ["春天的赏樱大会&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">六  花见酒</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "噗哈～果然说到赏樱花，就少不了这个呢～", "actor": 305030, "actorName": "伊势", "nameColor": "#a9f548"}, {"say": "伊势姐的喝法还是那么豪爽呢，那我也——", "actor": 305040, "actorName": "日向", "nameColor": "#a9f548"}, {"say": "嘻嘻嘻，「花见酒」，还真是诗意啊～", "actor": 301300, "actorName": "神风", "nameColor": "#a9f548"}, {"say": "重樱的风俗吗…真是不错呢", "actor": 403030, "actorName": "欧根亲王", "nameColor": "#a9f548"}, {"say": "在飘零的樱花下举杯共饮，倒也别具一番风味", "actor": 403030, "actorName": "欧根亲王", "nameColor": "#a9f548"}, {"say": "重樱的酒，美味…嗝——", "actor": 101170, "actorName": "拉菲", "nameColor": "#a9f548"}, {"say": "那边也是另一番的热闹场景呢～", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "已经能预感到一会将会变成的“炼狱”景象了呢，呵呵～", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}], "两个人的后夜祭": [{"stopbgm": true, "sequence": ["春天的赏樱大会&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">七  两个人的后夜祭</span><br>"]}, {"bgm": "story-2", "bgName": "bg_night", "say": "呼…虽然宴会本身让人开心，但宴会结束后的静寂，总是让人觉得有点落寞呢…", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "哎呀？指挥官老爷？您怎么在这里，还以为您早就休息了呢", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "难道是想要和我赏会夜樱～？", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "…（点头）", "actor": 0, "actorName": "0", "nameColor": "#a9f548"}, {"say": "呵呵…既然如此，那请您稍等，让我做点准备", "actor": 306030, "actorName": "凤翔", "nameColor": "#a9f548"}, {"say": "「老爷，今夜能有幸与您共赏繁星吗？」", "actor": 306031, "actorName": "凤翔 [秋枕梦]", "nameColor": "#a9f548"}, {"say": "！！！", "actor": 0, "actorName": "0", "nameColor": "#a9f548"}, {"say": "如何，心动了吗？指挥官老爷？", "actor": 306031, "actorName": "凤翔 [秋枕梦]", "nameColor": "#a9f548"}, {"say": "！！", "actor": 0, "actorName": "0", "nameColor": "#a9f548"}, {"say": "呵呵，有您的赞赏，凤翔就已经觉得满足了呢", "actor": 306031, "actorName": "凤翔 [秋枕梦]", "nameColor": "#a9f548"}, {"say": "那么，月见酒…就着美好的夜色与樱花干杯吧，老爷～？", "actor": 306031, "actorName": "凤翔 [秋枕梦]", "nameColor": "#a9f548"}]}, "EN": {"Spring Springs Forth": [{"stopbgm": true, "sequence": ["Flower Festival&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">Chapter 1 - Spring Springs Forth</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_room", "say": "*Whew*... It feels like it's gotten hot much earlier than last year...", "actor": 307030, "actorName": "Souryuu", "nameColor": "#a9f548"}, {"say": "It certainly does! Soon it will be spring.", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "The seasons go by quick...", "actor": 307030, "actorName": "Souryuu", "nameColor": "#a9f548"}, {"say": "They certainly do! Would you like a cup of tea?", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "Yes, please... Wait, Houshou?! How long have you been here...?", "actor": 307030, "actorName": "Souryuu", "nameColor": "#a9f548"}, {"say": "This is where you went, Houshou?! You must've mastered the art of masking your presence!", "actor": 307040, "actorName": "Hiryuu", "nameColor": "#a9f548"}, {"say": "Ah, sis, Houshou here gave me a hand with making this tea just earlier!", "actor": 307040, "actorName": "Hiryuu", "nameColor": "#a9f548"}, {"say": "I see, so she was helping you... Thanks, Houshou.", "actor": 307030, "actorName": "Souryuu", "nameColor": "#a9f548"}, {"say": "There's no need to thank me, I'm just glad to help~", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "Oh yeah, since spring is around the corner, the cherry trees should start blooming soon...", "actor": 307030, "actorName": "Souryuu", "nameColor": "#a9f548"}, {"say": "It's that time of year...", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "Then why don't we have a Flower Festival so we can watch them bloom together?", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "Nothing embodies the beauty of spring better than the blooming cherry tree, after all~", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "That sounds like a great idea! I think we should do it!", "actor": 307040, "actorName": "Hiryuu", "nameColor": "#a9f548"}, {"say": "I mean, sure, but... why does the idea of a Flower Festival excite you so much, Hiryuu?", "actor": 307030, "actorName": "Souryuu", "nameColor": "#a9f548"}, {"say": "Why? Because a Flower Festival is a festival for girls! I just have to attend it!", "actor": 307040, "actorName": "Hiryuu", "nameColor": "#a9f548"}, {"say": "Um... it's not exactly a girls-only festival, though...", "actor": 307030, "actorName": "Souryuu", "nameColor": "#a9f548"}, {"say": "If you're in favor of it, then let's do it! Please, allow me to make all the necessary preparations~", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}], "Blooming Beckoning": [{"stopbgm": true, "sequence": ["Flower Festival&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">Chapter 2 - Blooming Beckoning</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "I'll go out and tell people about the festival, then.", "actor": 307030, "actorName": "Souryuu", "nameColor": "#a9f548"}, {"say": "Oh, hi, Shoukaku and Zuikaku. Good timing.", "actor": 307030, "actorName": "Souryuu", "nameColor": "#a9f548"}, {"say": "What's up?", "actorName": "Shoukaku&Zuikaku", "nameColor": "#a9f548"}, {"say": "It is nice to see you, Souryuu.", "actor": 307050, "actorName": "Shoukaku", "nameColor": "#a9f548"}, {"say": "Ahaha, sorry for interrupting your stroll... You see, we're having a Flower Festival soon, and I'd like to invite you to come.", "actor": 307030, "actorName": "Souryuu", "nameColor": "#a9f548"}, {"say": "A Flower Festival... and we're invited?", "actor": 307060, "actorName": "Zuikaku", "nameColor": "#a9f548"}, {"say": "Ah yes, spring seems to have come early this year...", "actor": 307050, "actorName": "Shoukaku", "nameColor": "#a9f548"}, {"say": "It seems there will be some good company and good food as well, courtesy of Houshou.", "actor": 307030, "actorName": "Souryuu", "nameColor": "#a9f548"}, {"say": "We would love to come! You can expect to see us there!", "actor": 307060, "actorName": "Zuikaku", "nameColor": "#a9f548"}, {"say": "Zuikaku... your eagerness to accept offers may come back to haunt you in the future...", "actor": 307050, "actorName": "Shoukaku", "nameColor": "#a9f548"}, {"say": "I want to... see the flowers... too...", "actor": 301330, "actorName": "Kisaragi", "nameColor": "#a9f548"}, {"say": "Will there be candy? Because I wanna eat candy!", "actor": 301320, "actorName": "Mutsuki", "nameColor": "#a9f548"}, {"say": "Now, now... Everyone loves sweets, but didn't I teach you that eating too much of it is bad for you?", "actor": 307030, "actorName": "Souryuu", "nameColor": "#a9f548"}, {"say": "Ahaha, Souryuu is like a mother figure to them... That's what I would call \"sweet\"~", "actor": 307050, "actorName": "Shoukaku", "nameColor": "#a9f548"}], "Preparing for the Party": [{"stopbgm": true, "sequence": ["Flower Festival&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">Chapter 3 - Preparing for the Party</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "There... Now, could someone help me with these boxes~?", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "Sorry for leaving you to do everything alone... But I brought some people who can lend us a hand!", "actor": 307040, "actorName": "Hiryuu", "nameColor": "#a9f548"}, {"say": "Oh, who might they be...?", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "Me, for one!", "actor": 301310, "actorName": "Matsukaze", "nameColor": "#a9f548"}, {"say": "I can probably help you with the food as long as it's not too fancy!", "actor": 302040, "actorName": "Nagara", "nameColor": "#a9f548"}, {"say": "Please allow us to help you out as well.", "actor": 305010, "actorName": "Fusou", "nameColor": "#a9f548"}, {"say": "I'm so excited for the Flower Festival I can hardly wait!", "actor": 305020, "actorName": "Yamashiro", "nameColor": "#a9f548"}, {"say": "My, it's starting to get crowded in here!", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "All I did was tell them about the Flower Festival and they all came here to help!", "actor": 307040, "actorName": "Hiryuu", "nameColor": "#a9f548"}, {"say": "They must have really high expectations of it~", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "Then, to meet their expectations, I think we should make some gourmet food for all our guests to enjoy~", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}], "The Banquet Begins": [{"stopbgm": true, "sequence": ["Flower Festival&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">Chapter 4 - The Banquet Begins</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "Now then, let the Flower Festival begin!", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "Woohoo!", "actorName": "Everyone", "nameColor": "#a9f548"}, {"say": "We prepared a whole banquet worth of food, so dig in and enjoy yourselves~", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "Mmm! Sis, you have to try this tempura, it's amazing!", "actor": 307060, "actorName": "Zuikaku", "nameColor": "#a9f548"}, {"say": "I'm sure it is...", "actor": 307050, "actorName": "Shoukaku", "nameColor": "#a9f548"}, {"say": "I see! So this \"Flower Festival\" thing is all about stuffing your face with food!", "actor": 301110, "actorName": "Ikazuchi", "nameColor": "#a9f548"}, {"say": "I'm pretty sure it isn't...", "actor": 301130, "actorName": "Shiratsuyu", "nameColor": "#a9f548"}, {"say": "Hum, hum... I've never had melon bread this good before...", "actor": 302010, "actorName": "Yuubari", "nameColor": "#a9f548"}, {"say": "Ahh, what a perfectly sunny day... Perfect for a nap, too...", "actor": 301200, "actorName": "Nowaki", "nameColor": "#a9f548"}, {"say": "Hey, wait, where's Akatsuki? Wasn't she coming with you, Ikazuchi?", "actor": 301200, "actorName": "Nowaki", "nameColor": "#a9f548"}, {"say": "She left a note saying she had embarked on a journey to \"find the perfect snack to eat at the Flower Festival\"...", "actor": 301120, "actorName": "Inazuma", "nameColor": "#a9f548"}, {"say": "Uhh... didn't she leave that note like 3 days ago...?", "actor": 301110, "actorName": "Ikazuchi", "nameColor": "#a9f548"}, {"say": "...", "actorName": "Everyone", "nameColor": "#a9f548"}], "Cherry Flowers and Cheery Folks": [{"stopbgm": true, "sequence": ["Flower Festival&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">Chapter 5 - Cherry Flowers and Cheery Folks</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "There really is nothing that embodies spring better than the cherry tree.", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "And sitting underneath one, surrounded by friends and food... I can't think of anything more enjoyable.", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "You must've worked hard to make this gathering a reality, Houshou.", "actor": 307030, "actorName": "Souryuu", "nameColor": "#a9f548"}, {"say": "Yes, but seeing everyone enjoying themselves makes it all worth it... Hm? Do we have more guests coming?", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "Looks like this is the place. And looks like everyone's having a good time!", "actor": 401230, "actorName": "Z23", "nameColor": "#a9f548"}, {"say": "Not to mention all the yummy food they've got~", "actor": 201210, "actorName": "Javelin", "nameColor": "#a9f548"}, {"say": "And the alcohol...", "actor": 101170, "actorName": "Laffey", "nameColor": "#a9f548"}, {"say": "Yes, this is the Flower Festival – a Sakura Empire tradition. You can join us if you'd like.", "actor": 301050, "actorName": "Ayanami", "nameColor": "#a9f548"}, {"say": "We certainly would!", "actor": 401230, "actorName": "Z23", "nameColor": "#a9f548"}, {"say": "I think we can sit over here! Come on!", "actor": 201210, "actorName": "Javelin", "nameColor": "#a9f548"}, {"say": "The smell of sake... beckons me...", "actor": 101170, "actorName": "Laffey", "nameColor": "#a9f548"}, {"say": "Ahaha, how pleasant to see more people join us.", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}], "Sakura Sake": [{"stopbgm": true, "sequence": ["Flower Festival&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">Chapter 6 - Sakura Sake</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "*Glug glug*... Ahh, can't have a Flower Festival without something to drink!", "actor": 305030, "actorName": "Ise", "nameColor": "#a9f548"}, {"say": "Going straight for the sake, like always, eh... I think I'll have some, too...", "actor": 305040, "actorName": "Hyuuga", "nameColor": "#a9f548"}, {"say": "Hohoho~! Nothing says elegance like Flower Festival sake!", "actor": 301300, "actorName": "Kamikaze", "nameColor": "#a9f548"}, {"say": "I suppose this is part of the tradition... Can't say I dislike it.", "actor": 403030, "actorName": "Prinz Eugen", "nameColor": "#a9f548"}, {"say": "Drinking sake under a cherry tree waving in the wind feels... surprisingly charming.", "actor": 403030, "actorName": "Prinz Eugen", "nameColor": "#a9f548"}, {"say": "Yep, you can't top that Sakura Empire sake... *Buuuurp*...", "actor": 101170, "actorName": "Laffey", "nameColor": "#a9f548"}, {"say": "Oh dear, it seems they're getting busy with their beverages~", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "Hmm... I hope they don't have too much to drink, or else they might get \"shipfaced\"~", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}], "Private Time": [{"stopbgm": true, "sequence": ["Flower Festival&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">Chapter 7 - Private Time</span><br>"]}, {"bgm": "story-2", "bgName": "bg_night", "say": "The banquet was wonderful, but I felt rather lonely when it had ended and everyone went home...", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "Oh, is that you, Commander? I thought you had already gone to sleep...", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "Would you like to... see the moonlit cherry trees, together with me?", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "(Nod)", "actor": 0, "actorName": "0", "nameColor": "#a9f548"}, {"say": "Ahaha... I see. Then please wait a moment while I get ready.", "actor": 306030, "actorName": "Houshou", "nameColor": "#a9f548"}, {"say": "Oh, my beloved, please allow me to accompany you to see the cherry trees tonight.", "actor": 306031, "actorName": "Houshou [The Dream of the Autumn Pillow]", "nameColor": "#a9f548"}, {"say": "(Gulp!)", "actor": 0, "actorName": "0", "nameColor": "#a9f548"}, {"say": "Do you like my look? ...Does it excite you, Commander?", "actor": 306031, "actorName": "Houshou [The Dream of the Autumn Pillow]", "nameColor": "#a9f548"}, {"say": "!!!", "actor": 0, "actorName": "0", "nameColor": "#a9f548"}, {"say": "It is an honor to be admired by you, Commander...", "actor": 306031, "actorName": "Houshou [The Dream of the Autumn Pillow]", "nameColor": "#a9f548"}, {"say": "Now then, why don't we enjoy a drink beneath the moonlit cherry trees... my beloved?", "actor": 306031, "actorName": "Houshou [The Dream of the Autumn Pillow]", "nameColor": "#a9f548"}]}, "JP": {"早春日和": [{"stopbgm": true, "sequence": ["お花見大会&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">その一  早春日和</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_room", "say": "はあ……知らないうちになんだか暖かくなってきてますね……", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "そうですね～そろそろ春ですね～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "時の流れが早いですね……", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "そうですね～あ、お茶でもどうぞ～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "あ、どうも…――って、ほ、鳳翔さん！？いつからそこにいましたの！？……", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "わっ！？鳳翔さん、気配を消すのは流石です！", "actor": 307040, "actorName": "飛龍", "nameColor": "#a9f548"}, {"say": "姉さま、実はさっきお茶を用意した時ちょうど鳳翔さんに会って、少し手伝ってもらいました！", "actor": 307040, "actorName": "飛龍", "nameColor": "#a9f548"}, {"say": "そ、そういうことですか…ありがとうございます。", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "いえいえ、お気になさらず～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "そういえば…うちのサクラもそろそろ咲く頃ですね…", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "（にこにこ）", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "じゃあ…お花見とかでどうでしょう～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "春といえばサクラを愛でながら宴会ですね～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "おお！素晴らしいアイデアです！ぜひやりましょう！", "actor": 307040, "actorName": "飛龍", "nameColor": "#a9f548"}, {"say": "…まあ、お花見をやるのはいいけど、なんで飛龍が盛り上がってるの……？", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "だってこれってすなわち「女子会」じゃないですか！うん、ぼくもがんばりますよ！", "actor": 307040, "actorName": "飛龍", "nameColor": "#a9f548"}, {"say": "い、いや…そういうものじゃないと思うんだけど…", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "はいはい、準備はこの鳳翔におまかせください～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}], "花見の誘い": [{"stopbgm": true, "sequence": ["お花見大会&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">その二  花見の誘い</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "じゃあ、私がみんなに声を掛けますね。", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "あら、翔鶴と瑞鶴？ちょうどいいところに。", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "うん？", "actorName": "翔鶴&瑞鶴", "nameColor": "#a9f548"}, {"say": "蒼龍先輩ですか……", "actor": 307050, "actorName": "翔鶴", "nameColor": "#a9f548"}, {"say": "あははは…ごめんね、急に呼び止めて。今度みんなでお花見するんだけど、あなたたちも来ない？", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "お花見…ですか？", "actor": 307060, "actorName": "瑞鹤", "nameColor": "#a9f548"}, {"say": "そういえばもう春ですね……", "actor": 307050, "actorName": "翔鶴", "nameColor": "#a9f548"}, {"say": "鳳翔さんが美味しい料理を用意してくれるそうよ。", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "ぜひ私たちにも参加させてくださいお願いします！", "actor": 307060, "actorName": "瑞鹤", "nameColor": "#a9f548"}, {"say": "瑞鶴…将来悪い人に騙されないかお姉ちゃんすごく心配だわ…", "actor": 307050, "actorName": "翔鶴", "nameColor": "#a9f548"}, {"say": "如月も…おはなみ…いきたい…", "actor": 301330, "actorName": "如月", "nameColor": "#a9f548"}, {"say": "アメさんあるの？睦月、アメさんたべたい！", "actor": 301320, "actorName": "睦月", "nameColor": "#a9f548"}, {"say": "ほら、睦月ちゃん、如月ちゃん、甘いものはいいけど、食べ過ぎはダメって教えたでしょ？", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "うふふ、本当に「蒼龍先生」ですね…", "actor": 307050, "actorName": "翔鶴", "nameColor": "#a9f548"}], "お花見の準備": [{"stopbgm": true, "sequence": ["お花見大会&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">その三  お花見の準備</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "は～い、こちらの準備もお願いしますね～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "一人ではさすがに大変ですね…すみません！手伝ってくれる人を連れてきました！", "actor": 307040, "actorName": "飛龍", "nameColor": "#a9f548"}, {"say": "あらら、これは…", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "僕も手伝うよ！", "actor": 301310, "actorName": "松風", "nameColor": "#a9f548"}, {"say": "料理は…豪華なものは作れないけど、普通のなら手伝えると思うよ！", "actor": 302040, "actorName": "長良", "nameColor": "#a9f548"}, {"say": "私たちにも手伝わせてくださいね。", "actor": 305010, "actorName": "扶桑", "nameColor": "#a9f548"}, {"say": "お花見、すごく楽しみにしていました！", "actor": 305020, "actorName": "山城", "nameColor": "#a9f548"}, {"say": "うふふ、賑やかになってきましたね。", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "お花見やりましょうって言っただけで、みんな手伝いに来てくれました。", "actor": 307040, "actorName": "飛龍", "nameColor": "#a9f548"}, {"say": "結構期待されてますね～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "ではみんなの期待に応えられるよう、最高の料理をお作りいたしましょう～。", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}], "宴の始まり": [{"stopbgm": true, "sequence": ["お花見大会&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">その四  宴の始まり</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "では、春のお花見を始めましょう！", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "おー！", "actorName": "みんな", "nameColor": "#a9f548"}, {"say": "うふふ、料理は山ほど準備しましたので、どんどん召し上がってくださいませ～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "翔鶴姉～このテンプラ、美味しぃ～", "actor": 307060, "actorName": "瑞鹤", "nameColor": "#a9f548"}, {"say": "はいはい…", "actor": 307050, "actorName": "翔鶴", "nameColor": "#a9f548"}, {"say": "なるほどね！みんなが一緒にドカ食いするのが「オハナミ」ね！", "actor": 301110, "actorName": "雷", "nameColor": "#a9f548"}, {"say": "そうじゃないと思うんだけど…", "actor": 301130, "actorName": "白露", "nameColor": "#a9f548"}, {"say": "むむむ…メロンパン…んまぁい…", "actor": 302010, "actorName": "夕張", "nameColor": "#a9f548"}, {"say": "はあ～いいお天気～眠くなりそう…", "actor": 301200, "actorName": "野分", "nameColor": "#a9f548"}, {"say": "そういえば暁ちゃんは？雷ちゃんたちと一緒じゃないの？", "actor": 301200, "actorName": "野分", "nameColor": "#a9f548"}, {"say": "暁姉さん…「お花見で食べるおやつを買ってくるでござる」とメモを残して出かけました……", "actor": 301120, "actorName": "電", "nameColor": "#a9f548"}, {"say": "えっと…出かけたのって確か三日前じゃなかったっけ…", "actor": 301110, "actorName": "雷", "nameColor": "#a9f548"}, {"say": "……", "actorName": "みんな", "nameColor": "#a9f548"}], "桜に幕": [{"stopbgm": true, "sequence": ["お花見大会&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">その五  桜に幕</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "やはり春といえば桜ですね。", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "うふふ、桜の下でみんなと料理を囲む……こういう宴会はやはり楽しいですね。", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "鳳翔さんも準備お疲れ様です。", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "みんなが楽しんでいるのを見るとこっちもやりがいを感じますわ。あら？そこにいるのは――", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "ここが会場のようね。…わぁ、みんな盛り上がってる！", "actor": 401230, "actorName": "Z23", "nameColor": "#a9f548"}, {"say": "美味しそうな料理のかおり～", "actor": 201210, "actorName": "ジャベリン", "nameColor": "#a9f548"}, {"say": "あとお酒の…", "actor": 101170, "actorName": "ラフィー", "nameColor": "#a9f548"}, {"say": "重桜の伝統行事――「お花見」です。みんなも参加していいです。", "actor": 301050, "actorName": "綾波", "nameColor": "#a9f548"}, {"say": "綾波、ありがとう！", "actor": 401230, "actorName": "Z23", "nameColor": "#a9f548"}, {"say": "あ！あそこまだ空いてるね！早く行こ？", "actor": 201210, "actorName": "ジャベリン", "nameColor": "#a9f548"}, {"say": "お酒の…香り……美味しそう…", "actor": 101170, "actorName": "ラフィー", "nameColor": "#a9f548"}, {"say": "うふふ、なんだか微笑ましいですわ～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}], "花見で一杯": [{"stopbgm": true, "sequence": ["お花見大会&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">その六  花見で一杯</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "…ぷはぁ～やっぱりお花見にはこれがないとな～", "actor": 305030, "actorName": "伊勢", "nameColor": "#a9f548"}, {"say": "姉さんの飲みっぷりは相変わらず豪快ね…じゃあ私も――", "actor": 305040, "actorName": "日向", "nameColor": "#a9f548"}, {"say": "おーほっほっほ！「花見酒」とは風流よのう！", "actor": 301300, "actorName": "神風", "nameColor": "#a9f548"}, {"say": "重桜の風習ね…悪くないわ。", "actor": 403030, "actorName": "プリンツ・オイゲン", "nameColor": "#a9f548"}, {"say": "風に舞うサクラの下で酒を飲むなんて、意外と風情があるものね。", "actor": 403030, "actorName": "プリンツ・オイゲン", "nameColor": "#a9f548"}, {"say": "重桜のお酒、美味しい…けぷー", "actor": 101170, "actorName": "ラフィー", "nameColor": "#a9f548"}, {"say": "あら？あちらも騒がしいですね……", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "これは…あとでまた「ジゴク」が見れそうな飲みっぷりですわ～うふふ", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}], "二人の後夜祭": [{"stopbgm": true, "sequence": ["お花見大会&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">その七  二人の後夜祭</span><br>"]}, {"bgm": "story-2", "bgName": "bg_night", "say": "宴は楽しいですが、宴が終わった後の静けさはなんだか寂しいですね……", "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "あら？指揮官様？もうお休みになったと思ってましたけど…まだ起きていらっしゃったのですか？", "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "この鳳翔と夜ザクラを見たい、ですか？", "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "（ぺこり）", "actor": 0, "actorName": "0", "nameColor": "#a9f548"}, {"say": "うふふ…それでしたら、少々お待ち下さい。今支度いたしますわ。", "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "「旦那さん、今宵のお花見お供させておくんなし」", "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "！！！", "actor": 0, "actorName": "0", "nameColor": "#a9f548"}, {"say": "どうですか？…ドキドキしますか？指揮官様？", "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "！！", "actor": 0, "actorName": "0", "nameColor": "#a9f548"}, {"say": "うふふ、指揮官様からお褒めの言葉をいただけるなんて…鳳翔は満足しましたわ。", "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "では、続いては「月見酒」…月と夜ザクラの下で乾杯といたしましょうか？「旦那さま」？", "actorName": "鳳翔", "nameColor": "#a9f548"}]}, "KR": {"이른 봄 날씨": [{"stopbgm": true, "sequence": ["벚꽃놀이 대소동&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">제1장 - 이른 봄 날씨</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_room", "say": "하아……모르는 새 금방 또 따뜻해졌네……", "actor": 307030, "actorName": "소류", "nameColor": "#92fc63"}, {"say": "그렇네요~ 슬슬 봄이 오려나 봐요～", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "시간 참 빨리 가네……", "actor": 307030, "actorName": "소류", "nameColor": "#92fc63"}, {"say": "그렇네요~ 아, 차라도 한잔 드셔요~", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "아, 감사합니다…에엣?! 호, 호쇼 씨?! 언제부터 거기 있었던 거에요!?", "actor": 307030, "actorName": "소류", "nameColor": "#92fc63"}, {"say": "우와! 호쇼 씨, 대단해요! 이렇게까지 인기척을 지울 수 있다니!", "actor": 307040, "actorName": "히류", "nameColor": "#92fc63"}, {"say": "언니, 실은 아까 차를 준비할 때 호쇼 씨랑 만나게 되서, 살짝 도움을 좀 받았어요!", "actor": 307040, "actorName": "히류", "nameColor": "#92fc63"}, {"say": "그, 그렇게 된 건가요…감사합니다.", "actor": 307030, "actorName": "소류", "nameColor": "#92fc63"}, {"say": "아니에요~ 별일 아닌걸요~", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "그러고 보니…슬슬 벚꽃이 필 때가 다 되었네요…", "actor": 307030, "actorName": "소류", "nameColor": "#92fc63"}, {"say": "(생긋)", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "그럼…벚꽃놀이라도 어떠세요~?", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "봄이라면 역시 벚꽃을 구경하며 여는 연회가~", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "오오! 진짜 좋은 아이디어네요! 꼭 해보고 싶어요!", "actor": 307040, "actorName": "히류", "nameColor": "#92fc63"}, {"say": "…뭐, 벚꽃놀이 하는 건 좋지만…어째서 히류가 들떠있는 거야……?", "actor": 307030, "actorName": "소류", "nameColor": "#92fc63"}, {"say": "어째서냐니, 이건 '레이디스 파티' 잖아요! 음, 저도 노력할 테니까요!", "actor": 307040, "actorName": "히류", "nameColor": "#92fc63"}, {"say": "아, 아니…그런 게 아니라고 생각하는데…", "actor": 307030, "actorName": "소류", "nameColor": "#92fc63"}, {"say": "네에 네에, 준비는 이 호쇼에게 맡겨주세요~", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}], "벚꽃놀이 초대하기": [{"stopbgm": true, "sequence": ["벚꽃놀이 대소동&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">제2장 - 벚꽃놀이 초대하기</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "그럼, 내가 다들 한 번 불러볼게.", "actor": 307030, "actorName": "소류", "nameColor": "#92fc63"}, {"say": "어라, 쇼카쿠랑 즈이카쿠잖아? 마침 잘 됐네.", "actor": 307030, "actorName": "소류", "nameColor": "#92fc63"}, {"say": "음?", "actorName": "쇼카쿠&즈이카쿠", "nameColor": "#92fc63"}, {"say": "소류 선배구나……", "actor": 307050, "actorName": "쇼카쿠", "nameColor": "#92fc63"}, {"say": "아하하하…미안, 갑자기 불러 세워서. 이번에 다 같이 벚꽃놀이라도 가볼까 하는데, 너희들도 올래?", "actor": 307030, "actorName": "소류", "nameColor": "#92fc63"}, {"say": "벚꽃놀이…말인가요?", "actor": 307060, "actorName": "즈이카쿠", "nameColor": "#92fc63"}, {"say": "그러고 보니 이제 곧 봄이네요……", "actor": 307050, "actorName": "쇼카쿠", "nameColor": "#92fc63"}, {"say": "호쇼 씨가 맛있는 요리를 준다더라고.", "actor": 307030, "actorName": "소류", "nameColor": "#92fc63"}, {"say": "저희도 꼭 가고 싶습니다!", "actor": 307060, "actorName": "즈이카쿠", "nameColor": "#92fc63"}, {"say": "즈이카쿠도 참…나중에 나쁜 사람한테 속아 넘어가거나 하진 않을지 걱정되네…", "actor": 307050, "actorName": "쇼카쿠", "nameColor": "#92fc63"}, {"say": "키사라기도…벚꽃놀이…가고 싶어…", "actor": 301330, "actorName": "키사라기", "nameColor": "#92fc63"}, {"say": "사탕 있어? 무츠키, 사탕 먹고 싶어!", "actor": 301320, "actorName": "무츠키", "nameColor": "#92fc63"}, {"say": "무츠키, 키사라기, 단 걸 먹는 것 까진 괜찮지만, 너무 많이 먹으면 안됀다?", "actor": 307030, "actorName": "소류", "nameColor": "#92fc63"}, {"say": "우후후, 정말로 '소류 선생님' 이네요…", "actor": 307050, "actorName": "쇼카쿠", "nameColor": "#92fc63"}], "벚꽃놀이 준비하기": [{"stopbgm": true, "sequence": ["벚꽃놀이 대소동&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">제3장 - 벚꽃놀이 준비하기</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "네에~ 여기 준비도 부탁드릴게요~", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "혼자 하는 건 역시 힘들겠죠…죄송합니다! 도와줄 분들을 데려왔어요!", "actor": 307040, "actorName": "히류", "nameColor": "#92fc63"}, {"say": "어머머, 이 분은…", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "나도 도와줄게!", "actor": 301310, "actorName": "마츠카제 ", "nameColor": "#92fc63"}, {"say": "요리는…호화스러운 건 못 만들겠지만, 평범한 거라면 도울 수 있을 거야!", "actor": 302040, "actorName": "나가라", "nameColor": "#92fc63"}, {"say": "저희가 도와드릴게요~", "actor": 305010, "actorName": "후소", "nameColor": "#92fc63"}, {"say": "벚꽃놀이, 엄청 기대하고 있다구요~!", "actor": 305020, "actorName": "야마시로", "nameColor": "#92fc63"}, {"say": "우후후, 떠들썩해졌네요.", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "벚꽃놀이 하러 가자고만 말했는데, 다들 이렇게 도와준다고 와줬어요.", "actor": 307040, "actorName": "히류", "nameColor": "#92fc63"}, {"say": "다들 꽤 기대하고 있는 모양이네요~", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "그럼 모두의 기대에 부응할 수 있도록, 최고의 요리를 만들어보자고요~", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}], "연회의 시작": [{"stopbgm": true, "sequence": ["벚꽃놀이 대소동&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">제4장 - 연회의 시작</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "그럼, 봄철 벚꽃놀이를 시작해볼까요~!", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "오오~!", "actorName": "모두", "nameColor": "#92fc63"}, {"say": "우후후, 요리는 잔뜩 준비해두었으니, 마음껏 드세요~", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "쇼카쿠 언니~ 이 튀김 맛있어~", "actor": 307060, "actorName": "즈이카쿠", "nameColor": "#92fc63"}, {"say": "그래 그래…", "actor": 307050, "actorName": "쇼카쿠", "nameColor": "#92fc63"}, {"say": "그렇구나! 모두가 함께 폭풍 흡입하는 게 '벚꽃놀이' 구나!", "actor": 301110, "actorName": "이카즈치", "nameColor": "#92fc63"}, {"say": "그게 아니라고 생각하는데…", "actor": 301130, "actorName": "시라츠유", "nameColor": "#92fc63"}, {"say": "우걱우걱우걱…멜론빵…마이쪙…", "actor": 302010, "actorName": "유바리", "nameColor": "#92fc63"}, {"say": "하암~ 날씨 좋다~ 잠 올 거 같아…", "actor": 301200, "actorName": "노와키", "nameColor": "#92fc63"}, {"say": "그러고 보니 아카츠키는? 이카즈치네랑 같이 안 왔어?", "actor": 301200, "actorName": "노와키", "nameColor": "#92fc63"}, {"say": "아카츠키 언니…\"벚꽃놀이 때 먹을 간식을 사오겠소!\" 라는 메모를 남기고 밖으로 나갔습니다……", "actor": 301120, "actorName": "이나즈마", "nameColor": "#92fc63"}, {"say": "그러니까…나갔던 게 확실히 사흘 전이었던 거 같은데…", "actor": 301110, "actorName": "이카즈치", "nameColor": "#92fc63"}, {"say": "……", "actorName": "모두", "nameColor": "#92fc63"}], "하늘에 수 놓는 벚꽃": [{"stopbgm": true, "sequence": ["벚꽃놀이 대소동&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">제5장 - 하늘에 수 놓는 벚꽃</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "봄이라 하면 역시 벚꽃이죠.", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "우후후, 벚꽃 아래서 모두와 함께 요리를 즐기는 것……이런 연회는 역시 즐겁네요.", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "호쇼 씨도 준비하느라 고생하셨어요!", "actor": 307030, "actorName": "소류", "nameColor": "#92fc63"}, {"say": "모두가 즐거워하는 걸 보니 저도 준비한 보람이 있네요. 어머? 저기 있는 건……", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "연회는 여기서 하는 건가…와아, 다들 들떠있네!", "actor": 401230, "actorName": "Z23", "nameColor": "#92fc63"}, {"say": "맛있는 음식 냄새가 여기까지 나요~", "actor": 201210, "actorName": "재블린", "nameColor": "#92fc63"}, {"say": "그리고 술 냄새도…", "actor": 101170, "actorName": "라피", "nameColor": "#92fc63"}, {"say": "사쿠라 엠파이어의 전통 행사, 벚꽃놀이에요. 다들 와도 좋아요.", "actor": 301050, "actorName": "아야나미", "nameColor": "#92fc63"}, {"say": "아야나미, 고마워!", "actor": 401230, "actorName": "Z23", "nameColor": "#92fc63"}, {"say": "아! 저기 아직 비어있어! 빨리 가자~", "actor": 201210, "actorName": "재블린", "nameColor": "#92fc63"}, {"say": "술…냄새……맛있겠다…", "actor": 101170, "actorName": "라피", "nameColor": "#92fc63"}, {"say": "우후후, 왠지 흐뭇하네요~", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}], "꽃을 바라보며 한잔": [{"stopbgm": true, "sequence": ["벚꽃놀이 대소동&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">제6장 - 꽃을 바라보며 한잔</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "…푸하~ 역시 벚꽃놀이엔 이게 있어야지~", "actor": 305030, "actorName": "이세", "nameColor": "#92fc63"}, {"say": "언니는 여전히 술 마시는 게 호쾌하다니까~ 자 그럼 나도…", "actor": 305040, "actorName": "휴가", "nameColor": "#92fc63"}, {"say": "오~홋홋호! 벚꽃놀이에는 역시 풍류를 빼놓으면 섭하지!", "actor": 301300, "actorName": "카미카제", "nameColor": "#92fc63"}, {"say": "사쿠라 엠파이어의 풍습인가…나쁘지 않군.", "actor": 403030, "actorName": "프린츠 오이겐", "nameColor": "#92fc63"}, {"say": "바람에 나부끼는 벚꽃 아래서 한잔하는 것도, 의외로 운치가 있어.", "actor": 403030, "actorName": "프린츠 오이겐", "nameColor": "#92fc63"}, {"say": "사쿠라 엠파이어의 술, 맛있어…(꿀꺽꿀꺽꿀꺽)", "actor": 101170, "actorName": "라피", "nameColor": "#92fc63"}, {"say": "어라? 저쪽도 시끌벅적하네요……", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "이 술판은…나중에 또 '지옥' 이 펼쳐질 것 같은 분위기네요~ 우후후.", "actor": 306030, "actorName": "호쇼", "nameColor": "#92fc63"}], "둘만의 후야제": [{"stopbgm": true, "sequence": ["벚꽃놀이 대소동&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">제7장 - 둘만의 후야제</span><br>"]}, {"bgm": "story-2", "bgName": "bg_night", "say": "연회는 즐겁습니다만, 연회가 끝난 후의 이 조용함은 왠지 쓸쓸하네요……", "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "어라? 지휘관님? 벌써 쉬러 가신 줄 알았는데…아직 깨어있으셨나 봐요?", "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "이 호쇼와 함께 벚꽃을 보고 싶다…고요?", "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "(끄덕)", "actor": 0, "actorName": "0", "nameColor": "#92fc63"}, {"say": "우후후…그러시다면, 잠시만 기다려주셔요. 지금 준비할게요.", "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "\"낭군님, 오늘밤 꽃구경은 제가 모시도록 하겠사옵니다.\"", "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "!!!", "actor": 0, "actorName": "0", "nameColor": "#92fc63"}, {"say": "어떠세요? …두근두근하시나요? 지휘관님?", "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "!!", "actor": 0, "actorName": "0", "nameColor": "#92fc63"}, {"say": "우후후, 지휘관님께 칭찬받다니…호쇼는 몸 둘 바를 모르겠사와요.", "actorName": "호쇼", "nameColor": "#92fc63"}, {"say": "그럼, 계속해서 이 '월견주' 를…저 달과 밤 벚꽃을 바라보며 건배하실까요? 낭군님?", "actorName": "호쇼", "nameColor": "#92fc63"}]}, "TW": {"春日和": [{"stopbgm": true, "sequence": ["春天的賞櫻大會&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">一  春日和</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_room", "say": "呼…不知不覺，天氣開始轉暖了呢", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "是的呢，畢竟也差不多是春天了", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "時間過得真快啊…", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "是的呢，來，喝杯茶吧", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "喔，謝謝…——嗚哇！鳳、鳳翔！？什麼時候開始在這裡的…", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "哇！鳳翔手腳這麼快啊！", "actor": 307040, "actorName": "飛龍", "nameColor": "#a9f548"}, {"say": "剛在準備泡茶的時候遇到了鳳翔，就請她幫了點忙", "actor": 307040, "actorName": "飛龍", "nameColor": "#a9f548"}, {"say": "原、原來如此…", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "呵呵…一點小事～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "不過春天啊…櫻花也差不多要開了呢", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "（微笑）", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "那就…來開宴會吧～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "說到春天就是賞櫻大會了吧～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "哦哦！來開吧來開吧！", "actor": 307040, "actorName": "飛龍", "nameColor": "#a9f548"}, {"say": "…倒是個好主意，不過妳們還真有熱情呢…", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "這就是所謂的“女子會”嗎？好勒！", "actor": 307040, "actorName": "飛龍", "nameColor": "#a9f548"}, {"say": "不，我想應該不是妳想的那種…", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "準備就交給我吧～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}], "邀約": [{"stopbgm": true, "sequence": ["春天的賞櫻大會&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">二  邀約</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "那我就去邀請一下大家吧", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "啊啦，翔鶴和瑞鶴，來得正好", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "嗯？", "actorName": "翔鶴&瑞鶴", "nameColor": "#a9f548"}, {"say": "原來是蒼龍啊…", "actor": 307050, "actorName": "翔鶴", "nameColor": "#a9f548"}, {"say": "啊哈哈…突然叫住妳們不好意思，只是想問問妳們要不要一起來賞櫻花而已", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "賞櫻大會？", "actor": 307060, "actorName": "瑞鶴", "nameColor": "#a9f548"}, {"say": "也是，又到春天了呢…", "actor": 307050, "actorName": "翔鶴", "nameColor": "#a9f548"}, {"say": "還有鳳翔準備的美味食物哦", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "請務必讓我們參加！", "actor": 307060, "actorName": "瑞鶴", "nameColor": "#a9f548"}, {"say": "瑞鶴…姐姐開始擔心妳未來會不會被人騙了", "actor": 307050, "actorName": "翔鶴", "nameColor": "#a9f548"}, {"say": "如月也想參加宴會……", "actor": 301330, "actorName": "如月", "nameColor": "#a9f548"}, {"say": "有糖吃嗎？睦月也要吃糖！", "actor": 301320, "actorName": "睦月", "nameColor": "#a9f548"}, {"say": "吃太多甜食對身體可不好哦", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "讓人忍不住想叫一聲蒼龍老師呢…", "actor": 307050, "actorName": "翔鶴", "nameColor": "#a9f548"}], "祭典的準備": [{"stopbgm": true, "sequence": ["春天的賞櫻大會&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">三  祭典的準備</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "好～那就開始準備吧～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "一個人忙不過來的吧！看看我帶了些誰來～", "actor": 307040, "actorName": "飛龍", "nameColor": "#a9f548"}, {"say": "哎呀呀，這是", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "請讓我也幫點忙吧～", "actor": 301310, "actorName": "松風", "nameColor": "#a9f548"}, {"say": "料理嗎…雖然做不出很華麗的東西，幫忙做點平常的料理還是可以的～", "actor": 302040, "actorName": "長良", "nameColor": "#a9f548"}, {"say": "我們也來幫忙了～", "actor": 305010, "actorName": "扶桑", "nameColor": "#a9f548"}, {"say": "賞櫻大會呀，真是期待呢～", "actor": 305020, "actorName": "山城", "nameColor": "#a9f548"}, {"say": "哎呀呀，真是熱鬧呢", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "我說到賞櫻大會，大家就主動過來幫忙了呢～", "actor": 307040, "actorName": "飛龍", "nameColor": "#a9f548"}, {"say": "看來大家都對賞櫻大會很期待呀～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "好～那就來做出不辜負大家期待的賞櫻料理吧～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}], "宴會開幕": [{"stopbgm": true, "sequence": ["春天的賞櫻大會&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">四  宴會開幕</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "那麼～賞櫻大會～開始囉～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "喔！！", "actorName": "眾人", "nameColor": "#a9f548"}, {"say": "呵呵，這邊準備了非常多的料理喲，盡情享受吧～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "翔鶴姐～這個天婦羅好好吃～", "actor": 307060, "actorName": "瑞鶴", "nameColor": "#a9f548"}, {"say": "是是…——", "actor": 307050, "actorName": "翔鶴", "nameColor": "#a9f548"}, {"say": "原來如此！大家聚在一起大吃大喝就是所謂的“賞櫻大會”啊！", "actor": 301110, "actorName": "雷", "nameColor": "#a9f548"}, {"say": "我想應該不是這樣的…", "actor": 301130, "actorName": "白露", "nameColor": "#a9f548"}, {"say": "唔…菠蘿包，好吃…", "actor": 302010, "actorName": "夕張", "nameColor": "#a9f548"}, {"say": "哈欠～天氣好得讓人想要睡一覺了呢…", "actor": 301200, "actorName": "野分", "nameColor": "#a9f548"}, {"say": "話說曉呢？怎麼沒跟妳們一起來", "actor": 301200, "actorName": "野分", "nameColor": "#a9f548"}, {"say": "曉姐姐…留下了“我去買點賞櫻時可以吃的零食”的字條就出門了（遠目", "actor": 301120, "actorName": "電", "nameColor": "#a9f548"}, {"say": "那大約…是三天前的事情了（遠目", "actor": 301110, "actorName": "雷", "nameColor": "#a9f548"}, {"say": "……", "actorName": "眾人", "nameColor": "#a9f548"}], "花與幕": [{"stopbgm": true, "sequence": ["春天的賞櫻大會&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">五  櫻與幕</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "果然說到春天，就少不了櫻花呢", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "呵呵，不論什麼時候，舉辦宴會總是讓人感到開心呢", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "辛苦鳳翔準備了～", "actor": 307030, "actorName": "蒼龍", "nameColor": "#a9f548"}, {"say": "看到大家那麼開心，就覺得值得了呢，恩？那邊是——", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "這邊就是會場嗎？哇，好熱鬧！", "actor": 401230, "actorName": "Z23", "nameColor": "#a9f548"}, {"say": "我聞到美食的味道了～", "actor": 201210, "actorName": "標槍", "nameColor": "#a9f548"}, {"say": "酒香…", "actor": 101170, "actorName": "拉菲", "nameColor": "#a9f548"}, {"say": "重櫻春季特產——“賞櫻大會”…大家一起才好", "actor": 301050, "actorName": "綾波", "nameColor": "#a9f548"}, {"say": "謝謝綾波的邀請～", "actor": 401230, "actorName": "Z23", "nameColor": "#a9f548"}, {"say": "啊，那邊還有位置，我們快過去吧～", "actor": 201210, "actorName": "標槍", "nameColor": "#a9f548"}, {"say": "酒…的香氣——", "actor": 101170, "actorName": "拉菲", "nameColor": "#a9f548"}, {"say": "真是讓人會心一笑的場景呢～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}], "花見酒": [{"stopbgm": true, "sequence": ["春天的賞櫻大會&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">六  花見酒</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "噗哈～果然說到賞櫻花，就少不了這個呢～", "actor": 305030, "actorName": "伊勢", "nameColor": "#a9f548"}, {"say": "伊勢姐的喝法還是那麼豪爽呢，那我也——", "actor": 305040, "actorName": "日向", "nameColor": "#a9f548"}, {"say": "嘻嘻嘻，「花見酒」，還真是詩意啊～", "actor": 301300, "actorName": "神風", "nameColor": "#a9f548"}, {"say": "重櫻的風俗嗎…真是不錯呢", "actor": 403030, "actorName": "歐根親王", "nameColor": "#a9f548"}, {"say": "在飄零的櫻花下舉杯共飲，倒也別具一番風味", "actor": 403030, "actorName": "歐根親王", "nameColor": "#a9f548"}, {"say": "重櫻的酒，美味…嗝——", "actor": 101170, "actorName": "拉菲", "nameColor": "#a9f548"}, {"say": "那邊也是另一番的熱鬧場景呢～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "已經能預感到一會將會變成的“煉獄”景象了呢，呵呵～", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}], "兩個人的後夜祭": [{"stopbgm": true, "sequence": ["春天的賞櫻大會&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">七  兩個人的後夜祭</span><br>"]}, {"bgm": "story-2", "bgName": "bg_night", "say": "呼…雖然宴會本身讓人開心，但宴會結束後的靜寂，總是讓人覺得有點落寞呢…", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "哎呀？指揮官老爺？您怎麼在這裡，還以為您早就休息了呢", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "難道是想要和我賞會夜櫻～？", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "…（點頭）", "actor": 0, "actorName": "0", "nameColor": "#a9f548"}, {"say": "呵呵…既然如此，那請您稍等，讓我做點準備", "actor": 306030, "actorName": "鳳翔", "nameColor": "#a9f548"}, {"say": "「老爺，今夜能有幸與您共賞繁星嗎？」", "actor": 306031, "actorName": "鳳翔 [秋枕夢]", "nameColor": "#a9f548"}, {"say": "！！！", "actor": 0, "actorName": "0", "nameColor": "#a9f548"}, {"say": "如何，心動了嗎？指揮官老爺？", "actor": 306031, "actorName": "鳳翔 [秋枕夢]", "nameColor": "#a9f548"}, {"say": "！！", "actor": 0, "actorName": "0", "nameColor": "#a9f548"}, {"say": "呵呵，有您的讚賞，鳳翔就已經覺得滿足了呢", "actor": 306031, "actorName": "鳳翔 [秋枕夢]", "nameColor": "#a9f548"}, {"say": "那麼，月見酒…就著美好的夜色與櫻花乾杯吧，老爺～？", "actor": 306031, "actorName": "鳳翔 [秋枕夢]", "nameColor": "#a9f548"}]}}}