tor": 100000, "actorName": "汎用型ブリ", "nameColor": "#a9f548"}, {"say": "「ブリをベースにした『汎用型強化兵装』にゃ。工作用にゃ。戦場で使ってはいけないにゃ」", "actorName": "手紙", "nameColor": "#a9f548"}, {"say": "黄金の秘宝と似てるプリン？", "actor": 100000, "actorName": "汎用型ブリ", "nameColor": "#a9f548"}, {"say": "前に姉ちゃんと一緒に設計図を書いたからあんな夢を見たプリン？とにかくブリ、装備してパワーアッププリン！", "actor": 100000, "actorName": "汎用型ブリ", "nameColor": "#a9f548"}, {"say": "本当に姉ちゃんと似てるプリン！今日も姉ちゃんと一緒にプリン、プリン！", "actor": 100001, "actorName": "汎用型ブリ [汎用型強化兵装（工作用）＋α]", "nameColor": "#a9f548"}], "ブリと黄金の秘宝・sp": [{"bgm": "level03", "say": "戦いのときが来たプリン", "actor": 100001, "actorName": "汎用型ブリ [汎用型強化兵装（工作用）＋α]", "nameColor": "#a9f548"}, {"say": "そうだわ！勝負だプリン！", "actor": 100010, "actorName": "試作型ブリMKII", "nameColor": "#ff5c5c"}, {"say": "どういう展開だプリン！ ", "actor": 100020, "actorName": "特装型ブリMKIII", "nameColor": "#a9f548"}, {"say": "この工作用兵装の威力を見るプリン！", "actor": 100001, "actorName": "汎用型ブリ [汎用型強化兵装（工作用）＋α]", "nameColor": "#ff5c5c"}, {"say": "勝ったらスーパーニャンニャン1号を貸してもらうプリン！", "actor": 100010, "actorName": "試作型ブリMKII", "nameColor": "#ff5c5c"}, {"say": "分かったプリン！ ", "actor": 100020, "actorName": "特装型ブリMKIII", "nameColor": "#a9f548"}, {"say": "でもブリはカラフルだから最強プリン！ ", "actor": 100020, "actorName": "特装型ブリMKIII", "nameColor": "#a9f548"}, {"say": "かかってこいプリン！ ", "actor": 100020, "actorName": "特装型ブリMKIII", "nameColor": "#a9f548"}]}, "KR": {"황금의 보물·상편": [{"stopbgm": true, "sequence": ["황금의 보물&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">황금의 보물·상편</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "어느 날?·항구", "narration": true}, {"say": "푸링~♪ 오늘도 전력을 다해서! 푸링푸링~♪", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "푸링? 이상한 편지가 있는 것 같은데...?", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "이... 이건!?", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"sequence": ["<span style=\"font-size: 0.850em;\">「황금의 보물을 원하는 가냥?」</span><br>", "<span style=\"font-size: 0.850em;\">「원한다면 모든 것을 너에게 줄 수 있다냥, 찾아라!」</span><br>", "<span style=\"font-size: 0.850em;\">「모든 보물은 그 곳에 두었다냥!」</span><br>"]}, {"bgName": "bg_story_school", "say": "푸링? 황금!? 언니처럼 금빛으로 반짝이는 색!?", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "무슨 상황인지는 모르겠지만, 무지 대단할 것 같은 느낌이야!", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "아, 그런데 \"그 곳\"은 어디지? 푸링?", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "푸링? 편지에 또 종이가 있네? 서, 설마 이게 바로... 전설 속의 \"단서\"? 푸링?", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "좋아! 내가 전설 속의 보물을 푸링해주겠어! 푸링!", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}], "황금의 보물·중편": [{"bgm": "battle-1", "say": "여기가 모든 단서들이 가리키는 \"그 곳\"인가? 푸링...?", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "콰과과과과과과광——", "narration": true}, {"say": "푸링!? 저, 저건... 언니!?", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "어리석은 동생아! 너도 이 \"황금의 보물\"을 원하는 거냐?", "actor": 100010, "actorName": "시제형 부린 MKⅡ", "nameColor": "#ff5c5c"}, {"say": "그렇다면 나를 꺾어봐라! 진정한 강자만이 진정한 보물을 가질 자격이 있는 법! 푸링!", "actor": 100010, "actorName": "시제형 부린 MKⅡ", "nameColor": "#ff5c5c"}], "황금의 보물·하편": [{"bgm": "level03", "say": "하아아아아아앗!! 푸링!!!!", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "아무 소용 없어! 푸링! 너의 공격 나를 쓰러뜨릴 수 없어! 푸링!", "actor": 100010, "actorName": "시제형 부린 MKⅡ", "nameColor": "#ff5c5c"}, {"say": "그럼 이건 어떨까! 받아라! 나의 최후의 푸링이다!", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "푸흑...! 여, 여기서 질 순 없다! 푸링! 절대 넘겨줄 수 없어! 푸링!", "actor": 100010, "actorName": "시제형 부린 MKⅡ", "nameColor": "#ff5c5c"}, {"say": "이렇게 된 이상, 어쩔 수 없군! 푸링! 나와라!", "actor": 100010, "actorName": "시제형 부린 MKⅡ", "nameColor": "#ff5c5c"}, {"bgName": "bg_bigbuli", "say": "푸링!!??? 어, 엄청나게 커! 푸링!", "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "이 ”황금의 보물“만 있다면, 어떤 적이든 아무 문제 없어! 푸링!", "actorName": "시제형 부린 MKII?", "nameColor": "#ff5c5c"}, {"say": "이 몸은, 이걸 이용해서 이 세상의 지배자가 되었지! 푸링!!", "actorName": "시제형 부린 MKII?", "nameColor": "#ff5c5c"}, {"say": "어떻게 된 일인지 모르겠지만, 저게 바로 \"황금의 보물\"인거지? 푸링? 확실히 금빛으로 반짝이긴 하는데!?... 금빛으로 반짝인다? 푸링?", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "경고. 시스템 이상 발견냥. 경고——", "actorName": "？？？", "nameColor": "#ff5c5c"}, {"say": "푸링?", "actor": 100010, "actorName": "시제형 부린 MKⅡ", "nameColor": "#ff5c5c"}, {"say": "자폭 프로그램이 가동되었습니다. 카운트 다운, 10, 9, 8——", "actorName": "？？？", "nameColor": "#ff5c5c"}, {"say": "푸링!? 뭐가 어떻게 된거야? 푸링?", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "7、6、5——", "actorName": "？？？", "nameColor": "#ff5c5c"}, {"say": "이런, 역시 그 초록 고양이가 만든 물건은 신뢰가 간다니까! 푸링!", "actor": 100010, "actorName": "시제형 부린 MKⅡ", "nameColor": "#ff5c5c"}, {"say": "4、3、2——", "actorName": "？？？", "nameColor": "#ff5c5c"}, {"say": "푸링!? 설마 여기서 언니와 함께 별이 되는 건가!? 푸링!?", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "1，0——", "actorName": "？？？", "nameColor": "#ff5c5c"}, {"bgm": "story-1", "bgName": "bg_story_room", "say": "buli！！", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "푸링? 꿈인가? 푸링...?", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "정말 이상한 꿈이었어 푸링... 응? 이건?", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "「이것은 의뢰에 따라 제작한 \"범용형 강화 장비\"다냥. 하지만, 결국에는 \"업무용\" 장비이니까, 주의해라냥!」", "actorName": "편지", "nameColor": "#a9f548"}, {"say": "앗, 꿈 속의 그 \"황금의 보물\"이랑 비슷한데? 푸링?", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "운명인가? 아니면 저번에 언니랑 같이 이거에 대해 얘기를 나눠서 그런 꿈을 꾼건가? 푸링? 상관없어, 어쨌든 우선 교체해야지! 푸링!", "actor": 100000, "actorName": "범용형 부린", "nameColor": "#a9f548"}, {"say": "와아앗! 정말 언니랑 닮았잖아! 푸링! 좋아! 언니를 찾아가자! 오늘도 전력을 다해서! 푸링푸링~!", "actor": 100001, "actorName": "범용형 부린 [범용형 강화 장비(업무용)]", "nameColor": "#a9f548"}], "황금의 보물·특별편": [{"bgm": "level03", "say": "결판을 내자, 푸링!", "actor": 100001, "actorName": "범용형 부린 [범용형 강화 장비(업무용)]", "nameColor": "#a9f548"}, {"say": "좋아! 결판을 내자고~ 푸링, 푸링~!", "actor": 100010, "actorName": "시제형 부린 MKⅡ", "nameColor": "#ff5c5c"}, {"say": "이건 무슨 전개야, 푸링?", "actor": 100020, "actorName": "특장형 부린 MKIII", "nameColor": "#a9f548"}, {"say": "\"업무용\" 장비의 위력을 보여주마 푸링!", "actor": 100001, "actorName": "범용형 부린 [범용형 강화 장비(업무용)]", "nameColor": "#ff5c5c"}, {"say": "강해 보이는데? 그럼 신형 장비의 위력을 시험해 봐야겠네, 푸링!", "actor": 100010, "actorName": "시제형 부린 MKⅡ", "nameColor": "#ff5c5c"}, {"say": "푸링!? 맞다 푸링!", "actor": 100020, "actorName": "특장형 부린 MKIII", "nameColor": "#a9f548"}, {"say": "언니들은 색이 하나 밖에 없지만, 나랑 \"냥젤리 1호\"는 알록달록해, 어떤 색이든 다 있다고! 그러니까, 내가 언니들보다 강해, 푸링!", "actor": 100020, "actorName": "특장형 부린 MKIII", "nameColor": "#a9f548"}, {"say": "결판을 내주겠어! 푸링! 푸링!!", "actor": 100020, "actorName": "특장형 부린 MKIII", "nameColor": "#a9f548"}]}, "TW": {"黃金的秘寶·上篇": [{"stopbgm": true, "sequence": ["黃金的秘寶&nbsp;&nbsp;<span style=\"font-size: 0.750em;\">一 黃金的秘寶·上篇</span><br>"]}, {"bgm": "story-1", "bgName": "bg_story_school", "say": "某日？·港區", "narration": true}, {"say": "buli~♪今天也要全力以赴地bulibuli~♪", "actor": 100000, "actorName": "泛用型布里", "nameColor": "#a9f548"}, {"say": "buli？好像鑽出了奇怪的信…？", "actor": 100000, "actorName": "泛用型布里", "nameColor": "#a9f548"}, {"say": "這…這是！？", "actor": 100000, "actorName": "泛用型布里", "nameColor": "#a9f548"}, {"sequence": ["<span style=\"font-size: 0.850em;\">「想要黃金的秘寶喵？」</span><br>", "<span style=\"font-size: 0.850em;\">「想要的話可以全部給妳喵，去找吧！」</span><br>", "<span style=\"font-size: 0.850em;\">「所有的寶貝都放在那裡了喵！」</span><br>"]}, {"bgName": "bg_story_school", "say": "buli？黃金的！？是像姐姐那樣金閃閃的顏色嗎！", "actor": 100000, "actorName": "泛用型布里", "nameColor": "#a9f548"}, {"say": "雖然不知道是什麼情況，不過感覺好厲害的樣子！", "actor": 100000, "actorName": "泛用型布里", "nameColor": "#a9f548"}, {"say": "啊，不過“那裡”是哪裡buli？", "actor": 100000, "actorName": "泛用型布里", "nameColor": "#a9f548"}, {"say": "buli？信封裡還有一張單獨的紙條？難、難道說這就是…傳說中的“線索”buli？", "actor": 100000, "actorName": "泛用型布里", "nameColor": "#a9f548"}, {"say": "好！就讓人家把傳說中的秘寶buli出來吧buli！", "actor": 100000, "actorName": "泛用型布里", "nameColor": "#a9f5